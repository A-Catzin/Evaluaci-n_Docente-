---
import BaseLayout from './BaseLayout.astro';
export interface Props { titulo?: string; }
const { titulo = 'Coordinador — SED-360' } = Astro.props;
---
<BaseLayout titulo={titulo}>
  <div class="min-h-screen">
    <header class="sticky top-0 z-40 bg-white/80 backdrop-blur-md border-b border-slate-200/50 px-6 h-14 flex items-center justify-between">
      <div class="flex items-center gap-6">
        <a href="/coordinador/dashboard" class="font-semibold text-tup">SED-360 · Coordinador</a>
        <nav class="hidden sm:flex gap-1">
          <a href="/coordinador/dashboard" class="px-3 py-1.5 rounded-lg text-sm text-slate-600 hover:bg-tup/5">Dashboard</a>
          <a href="/coordinador/captura/observacion" class="px-3 py-1.5 rounded-lg text-sm text-slate-600 hover:bg-tup/5">Observación</a>
          <a href="/coordinador/reportes" class="px-3 py-1.5 rounded-lg text-sm text-slate-600 hover:bg-tup/5">Reportes</a>
        </nav>
      </div>
      <a href="/api/auth/signout" class="text-xs text-slate-400 hover:text-red-500">Salir</a>
    </header>
    <main class="p-6 max-w-7xl mx-auto"><slot /></main>
  </div>
</BaseLayout>
