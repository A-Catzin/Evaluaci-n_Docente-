---
/**
 * Callback OAuth — Página de intercambio de código (cliente)
 *
 * Muestra el estado del proceso de autenticación en pantalla
 * para facilitar el diagnóstico en desarrollo.
 */
import Layout from '../../layouts/Layout.astro';
---

<Layout titulo="SED-360 — Autenticando..." modoEnfoque={true}>
  <div class="flex flex-col items-center justify-center min-h-[80vh] gap-4 text-center px-4">
    <div id="spinner" class="w-12 h-12 rounded-full border-4 border-accion border-t-transparent animate-spin"></div>
    <p id="estado" class="text-slate-500 text-sm">Conectando con Google...</p>
    <div id="debug" class="mt-4 max-w-md w-full text-left"></div>
  </div>
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const cliente = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  async function intercambiarCodigo() {
    const url = new URL(window.location.href);
    const code = url.searchParams.get('code');
    const errorParam = url.searchParams.get('error');
    const errorDesc = url.searchParams.get('error_description');

    mostrarPaso('URL: ' + window.location.href);
    mostrarPaso('Code presente: ' + (code ? 'SI (' + code.substring(0, 12) + '...)' : 'NO'));
    mostrarPaso('Error param: ' + (errorParam || 'ninguno'));

    if (errorParam) {
      setEstado('Error de Google/Supabase: ' + errorParam, true);
      mostrarPaso('Error description: ' + (errorDesc || 'sin descripción'), true);
      mostrarPaso('Redirigiendo a /auth?error=oauth en 5s...');
      setTimeout(() => { window.location.href = '/auth?error=oauth'; }, 5000);
      return;
    }

    if (!code) {
      setEstado('No se recibió código de autorización', true);
      mostrarPaso('Posible causa: Redirect URL no configurada en Supabase', true);
      return;
    }

    setEstado('Intercambiando código por sesión...');
    mostrarPaso('Llamando a exchangeCodeForSession...');

    try {
      const { data, error } = await cliente.auth.exchangeCodeForSession(code);

      if (error) {
        setEstado('Error al intercambiar código', true);
        mostrarPaso('Error: ' + error.message, true);
        mostrarPaso('Status: ' + (error.status || 'N/A'), true);
        if (error.message.includes('code verifier')) {
          mostrarPaso('⚠️ El code_verifier no coincide. ¿Usaste el mismo navegador que inició el flujo?', true);
        }
        return;
      }

      if (!data.session) {
        setEstado('No se recibió sesión', true);
        mostrarPaso('El intercambio fue exitoso pero no hay datos de sesión', true);
        return;
      }

      setEstado('¡Sesión establecida! Redirigiendo...', false);
      mostrarPaso('Usuario: ' + (data.session.user?.email || 'desconocido'));
      mostrarPaso('Redirigiendo a /evaluador...');
      setTimeout(() => { window.location.href = '/evaluador'; }, 1000);
    } catch (err) {
      setEstado('Error inesperado', true);
      mostrarPaso('Excepción: ' + (err instanceof Error ? err.message : String(err)), true);
    }
  }

  intercambiarCodigo();
</script>
