---
import LayoutAdmin from '../../layouts/LayoutAdmin.astro';
import { obtenerUsuarios, buscarUsuarios, type UsuarioConNombre } from '../../services/usuarios';
import type { RolUsuario } from '../../types/supabase';

const rolFiltro = (Astro.url.searchParams.get('rol') as RolUsuario) || undefined;
const busqueda = Astro.url.searchParams.get('q') || '';

let usuarios: UsuarioConNombre[] = [];
let errorMsg = '';

try {
  if (busqueda) {
    usuarios = await buscarUsuarios(busqueda);
    if (rolFiltro) usuarios = usuarios.filter(u => u.rol === rolFiltro);
  } else {
    usuarios = await obtenerUsuarios(rolFiltro);
  }
} catch (e) {
  errorMsg = e instanceof Error ? e.message : 'Error al cargar usuarios';
}

const ROLES: RolUsuario[] = ['superadmin', 'coordinador', 'docente', 'estudiante'];
const ETIQUETAS_ROL: Record<string, string> = {
  superadmin: 'Administrador', coordinador: 'Coordinador', docente: 'Docente', estudiante: 'Estudiante'
};
const COLOR_ROL: Record<string, string> = {
  superadmin: 'bg-purple-50 text-purple-700', coordinador: 'bg-blue-50 text-blue-700',
  docente: 'bg-emerald-50 text-emerald-700', estudiante: 'bg-slate-50 text-slate-700'
};
---

<LayoutAdmin titulo="Usuarios — Admin">
  <div class="animate-flotar-entrada">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-3xl font-bold text-tup">Gestión de Usuarios</h1>
      <span class="text-sm text-slate-400">{usuarios.length} usuarios</span>
    </div>

    <!-- Filtros y búsqueda -->
    <div class="bg-white rounded-2xl p-4 shadow-tarjeta mb-6 flex flex-wrap gap-3 items-center">
      <form method="GET" class="flex flex-wrap gap-3 items-center w-full">
        <!-- Búsqueda -->
        <input type="text" name="q" value={busqueda} placeholder="Buscar por nombre, email o matrícula..." class="flex-1 min-w-[200px] rounded-xl border border-slate-200 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-tup" />
        <!-- Filtro por rol -->
        <select name="rol" class="rounded-xl border border-slate-200 px-3 py-2.5 text-sm" onchange="this.form.submit()">
          <option value="">Todos los roles</option>
          {ROLES.map(r => (<option value={r} selected={rolFiltro === r}>{ETIQUETAS_ROL[r]}</option>))}
        </select>
        <button type="submit" class="px-4 py-2.5 rounded-xl bg-tup text-white text-sm font-medium hover:bg-tup/90">Buscar</button>
        {(busqueda || rolFiltro) && (<a href="/admin/usuarios" class="px-4 py-2.5 rounded-xl border border-slate-200 text-sm text-slate-500 hover:bg-slate-50">Limpiar</a>)}
      </form>
    </div>

    <!-- Error -->
    {errorMsg && (<div class="bg-red-50 border border-red-200 rounded-xl p-4 text-red-700 text-sm mb-6">{errorMsg}</div>)}

    <!-- Tabla de usuarios -->
    <div class="bg-white rounded-2xl shadow-tarjeta overflow-hidden">
      {usuarios.length === 0 ? (
        <div class="p-12 text-center text-slate-400">No se encontraron usuarios.</div>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200">
                <th class="text-left px-4 py-3 font-semibold text-slate-600 text-xs uppercase">Usuario</th>
                <th class="text-left px-4 py-3 font-semibold text-slate-600 text-xs uppercase">Email</th>
                <th class="text-left px-4 py-3 font-semibold text-slate-600 text-xs uppercase">ID / Matrícula</th>
                <th class="text-center px-4 py-3 font-semibold text-slate-600 text-xs uppercase">Rol Actual</th>
                <th class="text-center px-4 py-3 font-semibold text-slate-600 text-xs uppercase">Cambiar a</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              {usuarios.map(u => (
                <tr class="hover:bg-slate-50 transition-colors" id={`user-${u.id}`}>
                  <td class="px-4 py-3">
                    <div class="flex items-center gap-3">
                      <div class="w-9 h-9 rounded-lg bg-hero-tup flex items-center justify-center text-white font-bold text-xs">{u.nombre_completo.charAt(0).toUpperCase()}</div>
                      <div>
                        <p class="font-medium text-slate-800">{u.nombre_completo}</p>
                        <p class="text-xs text-slate-400">ID: {u.id.substring(0, 8)}...</p>
                      </div>
                    </div>
                  </td>
                  <td class="px-4 py-3 text-slate-600">{u.email}</td>
                  <td class="px-4 py-3 text-slate-600 font-mono text-xs">{u.matricula_o_empleado}</td>
                  <td class="px-4 py-3 text-center">
                    <span class={`inline-flex px-2.5 py-1 rounded-lg text-xs font-medium ${COLOR_ROL[u.rol] || 'bg-slate-50 text-slate-700'}`}>{ETIQUETAS_ROL[u.rol] || u.rol}</span>
                  </td>
                  <td class="px-4 py-3">
                    <div class="flex items-center justify-center gap-1">
                      {ROLES.filter(r => r !== u.rol).map(r => (
                        <button
                          class={`px-2.5 py-1 rounded-lg text-xs font-medium border transition-colors ${COLOR_ROL[r]} hover:opacity-80`}
                          onclick={`cambiarRol('${u.id}','${r}',this)`}
                        >{ETIQUETAS_ROL[r]}</button>
                      ))}
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>

    <!-- Toast -->
    <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 hidden px-6 py-3 rounded-xl text-sm font-medium shadow-modal" role="alert"></div>
  </div>
</LayoutAdmin>

<script is:inline>
  function cambiarRol(userId, nuevoRol, btn) {
    if (!confirm('¿Cambiar el rol de este usuario a ' + nuevoRol + '?')) return;
    btn.disabled = true;
    btn.textContent = '...';

    fetch('/api/admin/cambiar-rol', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ user_id: userId, rol: nuevoRol }),
    }).then(function (r) { return r.json(); })
      .then(function (data) {
        if (data.success) {
          mostrarToast('Rol cambiado a ' + nuevoRol, false);
          setTimeout(function () { location.reload(); }, 800);
        } else {
          mostrarToast(data.error || 'Error al cambiar rol', true);
          btn.disabled = false;
          btn.textContent = nuevoRol;
        }
      }).catch(function () {
        mostrarToast('Error de conexión', true);
        btn.disabled = false;
      });
  }

  function mostrarToast(mensaje, error) {
    var t = document.getElementById('toast');
    if (!t) return;
    t.textContent = mensaje;
    t.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-xl text-sm font-medium shadow-modal ' + (error ? 'bg-red-600 text-white' : 'bg-emerald-600 text-white');
    t.classList.remove('hidden');
    setTimeout(function () { t.classList.add('hidden'); }, 3000);
  }
</script>
