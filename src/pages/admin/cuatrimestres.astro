---
import LayoutAdmin from '../../layouts/LayoutAdmin.astro';
import { obtenerCuatrimestres } from '../../services/catalogos';

const cuatrimestres = await obtenerCuatrimestres();
---

<LayoutAdmin titulo="Cuatrimestres — Admin">
  <div class="animate-flotar-entrada">
    <div class="flex items-center justify-between mb-6"><h1 class="text-3xl font-bold text-tup">Cuatrimestres</h1></div>

    <!-- Formulario para agregar -->
    <div class="bg-white rounded-2xl p-4 shadow-tarjeta mb-6">
      <form id="form-nueva" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
        <input type="text" id="input-clave" placeholder="Clave (ej: 26-1)*" required class="rounded-xl border border-slate-200 px-3 py-2.5 text-sm" />
        <input type="text" id="input-nombre" placeholder="Nombre*" required class="rounded-xl border border-slate-200 px-3 py-2.5 text-sm" />
        <input type="date" id="input-inicio" class="rounded-xl border border-slate-200 px-3 py-2.5 text-sm" />
        <input type="date" id="input-fin" class="rounded-xl border border-slate-200 px-3 py-2.5 text-sm" />
        <button type="submit" class="px-4 py-2.5 rounded-xl bg-tup text-white text-sm font-medium">Agregar</button>
      </form>
    </div>

    <!-- Tabla -->
    <div class="bg-white rounded-2xl shadow-tarjeta overflow-hidden">
      <table class="w-full text-sm">
        <thead><tr class="bg-slate-50 border-b"><th class="text-center px-3 py-3 text-xs uppercase text-slate-600">Clave</th><th class="text-center px-3 py-3 text-xs uppercase text-slate-600">Nombre</th><th class="text-center px-3 py-3 text-xs uppercase text-slate-600">Inicio</th><th class="text-center px-3 py-3 text-xs uppercase text-slate-600">Fin</th><th class="text-center px-3 py-3 text-xs uppercase text-slate-600">Estado</th><th class="text-center px-3 py-3 text-xs uppercase text-slate-600">Acciones</th></tr></thead>
        <tbody class="divide-y">
          {cuatrimestres.map(c => (
            <tr class="hover:bg-slate-50">
              <td class="px-3 py-3 text-center font-mono text-xs">{c.clave}</td>
              <td class="px-3 py-3 text-center">
                <span class="texto-nombre">{c.nombre}</span>
                <input type="text" class="edit-nombre hidden rounded-lg border border-slate-200 px-2 py-1 text-xs text-center w-full" value={c.nombre} />
              </td>
              <td class="px-3 py-3 text-center text-xs">
                <span class="texto-inicio">{c.fecha_inicio || '—'}</span>
                <input type="date" class="edit-inicio hidden rounded-lg border border-slate-200 px-2 py-1 text-xs" value={c.fecha_inicio || ''} />
              </td>
              <td class="px-3 py-3 text-center text-xs">
                <span class="texto-fin">{c.fecha_fin || '—'}</span>
                <input type="date" class="edit-fin hidden rounded-lg border border-slate-200 px-2 py-1 text-xs" value={c.fecha_fin || ''} />
              </td>
              <td class="px-3 py-3 text-center">
                <button class={`toggle-btn px-2 py-0.5 rounded-lg text-xs font-medium ${c.cerrado ? 'bg-slate-100 text-slate-400' : c.activo ? 'bg-emerald-50 text-emerald-700' : 'bg-amber-50 text-amber-700'}`} data-id={c.id} data-activa={c.activo} data-cerrado={c.cerrado}>{c.cerrado ? 'Cerrado' : c.activo ? 'Activo' : 'Inactivo'}</button>
              </td>
              <td class="px-3 py-3 text-center">
                <button class="btn-editar text-xs text-tup hover:underline mr-2" data-id={c.id}>Editar</button>
                <button class="btn-guardar text-xs text-emerald-600 hover:underline mr-2 hidden" data-id={c.id}>Guardar</button>
                <button class="btn-eliminar text-xs text-red-500 hover:underline" data-id={c.id}>Eliminar</button>
              </td>
            </tr>
          ))}
          {cuatrimestres.length === 0 && <tr><td colspan="6" class="text-center py-12 text-slate-400">No hay cuatrimestres.</td></tr>}
        </tbody>
      </table>
    </div>
    <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 hidden px-6 py-3 rounded-xl text-sm font-medium shadow-modal"></div>
  </div>
</LayoutAdmin>

<script is:inline>
  function toast(m,e){var t=document.getElementById('toast');t.textContent=m;t.className='fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-xl text-sm font-medium shadow-modal '+(e?'bg-red-600 text-white':'bg-emerald-600 text-white');t.classList.remove('hidden');setTimeout(function(){t.classList.add('hidden')},3000)}

  document.getElementById('form-nueva').addEventListener('submit',async function(e){
    e.preventDefault(); var c=document.getElementById('input-clave').value.trim(); var n=document.getElementById('input-nombre').value.trim();
    if(!c||!n)return;
    var res=await fetch('/api/admin/cuatrimestres',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'create',clave:c,nombre:n,fecha_inicio:document.getElementById('input-inicio').value||null,fecha_fin:document.getElementById('input-fin').value||null})});
    if(res.ok){toast('Cuatrimestre agregado',false);setTimeout(function(){location.reload()},500)}else{var d=await res.json();toast(d.error||'Error',true)}
  });

  document.querySelectorAll('.toggle-btn').forEach(function(b){b.addEventListener('click',async function(){
    var id=parseInt(this.dataset.id); var a=this.dataset.activa==='true'; var c=this.dataset.cerrado==='true';
    if(!c){ var res=await fetch('/api/admin/cuatrimestres',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'update',id,activo:!a})});
    if(res.ok)location.reload();else toast('Error',true);}
  })});

  document.querySelectorAll('.btn-eliminar').forEach(function(b){b.addEventListener('click',async function(){
    if(!confirm('¿Eliminar este cuatrimestre?'))return;
    var res=await fetch('/api/admin/cuatrimestres',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'delete',id:parseInt(this.dataset.id)})});
    if(res.ok){toast('Eliminado',false);setTimeout(function(){location.reload()},500)}else{var d=await res.json();toast(d.error||'Error',true)}
  })});

  document.querySelectorAll('.btn-editar').forEach(function(b){b.addEventListener('click',function(){
    var row=this.closest('tr');row.querySelectorAll('.texto-nombre,.texto-inicio,.texto-fin').forEach(function(e){e.classList.add('hidden')});row.querySelectorAll('.edit-nombre,.edit-inicio,.edit-fin').forEach(function(e){e.classList.remove('hidden')});this.classList.add('hidden');row.querySelector('.btn-guardar').classList.remove('hidden');
  })});

  document.querySelectorAll('.btn-guardar').forEach(function(b){b.addEventListener('click',async function(){
    var row=this.closest('tr'); var n=row.querySelector('.edit-nombre').value.trim(); if(!n)return;
    var res=await fetch('/api/admin/cuatrimestres',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({action:'update',id:parseInt(this.dataset.id),nombre:n,fecha_inicio:row.querySelector('.edit-inicio').value||null,fecha_fin:row.querySelector('.edit-fin').value||null})});
    if(res.ok){toast('Guardado',false);setTimeout(function(){location.reload()},500)}else{var d=await res.json();toast(d.error||'Error',true)}
  })});
</script>
