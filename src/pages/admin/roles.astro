---
import LayoutAdmin from '../../layouts/LayoutAdmin.astro';
import { obtenerUsuarios, type UsuarioConNombre } from '../../services/usuarios';
import type { RolUsuario } from '../../types/supabase';

const rolFiltro = (Astro.url.searchParams.get('rol') as RolUsuario) || undefined;
const busqueda = Astro.url.searchParams.get('q') || '';

let usuarios: UsuarioConNombre[] = [];
let errorMsg = '';

try {
  usuarios = await obtenerUsuarios(rolFiltro);
  if (busqueda) {
    const t = busqueda.toLowerCase();
    usuarios = usuarios.filter(u => u.nombre_completo.toLowerCase().includes(t) || u.email.toLowerCase().includes(t));
  }
} catch (e) { errorMsg = e instanceof Error ? e.message : 'Error'; }

const ROLES: RolUsuario[] = ['superadmin','coordinador','docente','estudiante'];
const ETIQUETAS: Record<string,string> = {superadmin:'Administrador',coordinador:'Coordinador',docente:'Docente',estudiante:'Estudiante'};
const COLOR: Record<string,string> = {superadmin:'bg-purple-50 text-purple-700',coordinador:'bg-blue-50 text-blue-700',docente:'bg-emerald-50 text-emerald-700',estudiante:'bg-slate-50 text-slate-700'};
---

<LayoutAdmin titulo="Roles — Admin">
  <div class="animate-flotar-entrada">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-3xl font-bold text-tup">Asignación de Roles</h1>
      <span class="text-sm text-slate-400">{usuarios.length} usuarios</span>
    </div>

    <div class="bg-white rounded-2xl p-4 shadow-tarjeta mb-6">
      <form method="GET" class="flex flex-wrap gap-3 items-center">
        <input type="text" name="q" value={busqueda} placeholder="Buscar por nombre o email..." class="flex-1 min-w-[200px] rounded-xl border border-slate-200 px-4 py-2.5 text-sm focus:ring-2 focus:ring-tup focus:outline-none" />
        <select name="rol" class="rounded-xl border border-slate-200 px-3 py-2.5 text-sm" onchange="this.form.submit()">
          <option value="">Todos</option>
          {ROLES.map(r => (<option value={r} selected={rolFiltro === r}>{ETIQUETAS[r]}</option>))}
        </select>
        <button type="submit" class="px-4 py-2.5 rounded-xl bg-tup text-white text-sm font-medium">Filtrar</button>
        {(busqueda || rolFiltro) && (<a href="/admin/roles" class="px-4 py-2.5 rounded-xl border border-slate-200 text-sm text-slate-500">Limpiar</a>)}
      </form>
    </div>

    {errorMsg && (<div class="bg-red-50 border border-red-200 rounded-xl p-4 text-red-700 text-sm mb-6">{errorMsg}</div>)}

    <div class="bg-white rounded-2xl shadow-tarjeta overflow-hidden">
      {usuarios.length === 0 ? (
        <div class="p-12 text-center text-slate-400">No se encontraron usuarios.</div>
      ) : (
        <table class="w-full text-sm">
          <thead><tr class="bg-slate-50 border-b"><th class="text-left px-4 py-3 text-xs uppercase text-slate-600">Usuario</th><th class="text-left px-4 py-3 text-xs uppercase text-slate-600">Email</th><th class="text-center px-4 py-3 text-xs uppercase text-slate-600">Rol Actual</th><th class="text-center px-4 py-3 text-xs uppercase text-slate-600">Cambiar a</th></tr></thead>
          <tbody class="divide-y">{usuarios.map(u => (<tr class="hover:bg-slate-50"><td class="px-4 py-3 font-medium">{u.nombre_completo}</td><td class="px-4 py-3 text-slate-600 text-xs">{u.email}</td><td class="px-4 py-3 text-center"><span class={`px-2.5 py-1 rounded-lg text-xs font-medium ${COLOR[u.rol]}`}>{ETIQUETAS[u.rol]}</span></td><td class="px-4 py-3"><div class="flex justify-center gap-1">{ROLES.filter(r => r !== u.rol).map(r => (<button class={`px-2.5 py-1 rounded-lg text-xs font-medium border hover:opacity-80 transition-opacity ${COLOR[r]}`} onclick={`cambiarRol('${u.id}','${r}',this)`}>{ETIQUETAS[r]}</button>))}</div></td></tr>))}</tbody>
        </table>
      )}
    </div>
    <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 hidden px-6 py-3 rounded-xl text-sm font-medium shadow-modal"></div>
  </div>
</LayoutAdmin>

<script is:inline>
  function toast(m,e){var t=document.getElementById('toast');t.textContent=m;t.className='fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-xl text-sm font-medium shadow-modal '+(e?'bg-red-600 text-white':'bg-emerald-600 text-white');t.classList.remove('hidden');setTimeout(function(){t.classList.add('hidden')},3000)}
  function cambiarRol(uid,rol,btn){
    if(!confirm('¿Cambiar rol a '+rol+'?'))return;
    btn.disabled=true;btn.textContent='...';
    fetch('/api/admin/cambiar-rol',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({user_id:uid,rol:rol})})
    .then(r=>r.json()).then(d=>{if(d.success){toast('Rol cambiado',false);setTimeout(function(){location.reload()},600)}else{toast(d.error||'Error',true);btn.disabled=false}})
    .catch(function(){toast('Error de conexión',true);btn.disabled=false});
  }
</script>
