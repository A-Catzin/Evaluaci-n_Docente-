---
import LayoutAdmin from '../../layouts/LayoutAdmin.astro';
import { obtenerCuatrimestres, obtenerCuatrimestreActivo } from '../../services/catalogos';
import { obtenerDocentes } from '../../services/docentes';
import { obtenerClienteSuperbase } from '../../lib/supabaseClient';

const cuatrimestre = await obtenerCuatrimestreActivo();
const cuatrimestres = await obtenerCuatrimestres();
const idSeleccionado = Astro.url.searchParams.get('cuatrimestre') || cuatrimestre?.id?.toString() || '';
const docentes = await obtenerDocentes();
const cliente = obtenerClienteSuperbase();

// Calcular progreso por docente desde tablas individuales
const { data: obsData } = await cliente.from('observaciones').select('docente_id');
const { data: coordData } = await cliente.from('evaluacion_coordinacion').select('docente_id');
const { data: planData } = await cliente.from('planeaciones').select('docente_id').eq('estado', 'Aprobado');
const { data: diagData } = await cliente.from('autodiagnosticos').select('docente_id');

const obsSet = new Set((obsData||[]).map(o=>o.docente_id));
const coordSet = new Set((coordData||[]).map(c=>c.docente_id));
const planSet = new Set((planData||[]).map(p=>p.docente_id));
const diagSet = new Set((diagData||[]).map(d=>d.docente_id));

interface FilaDashboard { id: number; nombre: string; apellidos: string; email: string; instrumentos: number; final360: number|null; cat360: string; }
const filas: FilaDashboard[] = docentes.map(d => {
  const inst = [obsSet.has(d.id)?1:0, coordSet.has(d.id)?1:0, planSet.has(d.id)?1:0, diagSet.has(d.id)?1:0];
  const total = inst.reduce((a,b)=>a+b,0);
  return { id: d.id, nombre: d.nombre, apellidos: d.apellidos, email: d.email, instrumentos: total, final360: null, cat360: '—' };
});

const totalDocentes = docentes.length;
const totalEvaluados = filas.filter(f => f.instrumentos > 0).length;
const cuatrimestreSel = cuatrimestres.find(c => c.id.toString() === idSeleccionado) || cuatrimestre;
---

<LayoutAdmin titulo="Dashboard — Admin">
  <div class="animate-flotar-entrada">
    <div class="flex items-center justify-between mb-6">
      <div><h1 class="text-3xl font-bold text-tup">Dashboard Administrativo</h1><p class="text-slate-500">{cuatrimestreSel?.nombre || 'Sin cuatrimestre activo'}</p></div>
      <form method="GET" class="flex items-center gap-2">
        <select name="cuatrimestre" class="rounded-xl border border-slate-200 px-3 py-2 text-sm" onchange="this.form.submit()">{cuatrimestres.map(c => (<option value={c.id} selected={c.id.toString()===idSeleccionado}>{c.nombre}</option>))}</select>
      </form>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <div class="bg-white rounded-2xl p-5 shadow-tarjeta"><p class="text-xs text-slate-400 uppercase">Docentes</p><p class="text-3xl font-bold text-tup mt-1">{totalDocentes}</p><p class="text-xs text-slate-400 mt-1">{totalEvaluados} evaluados</p></div>
      <div class="bg-white rounded-2xl p-5 shadow-tarjeta"><p class="text-xs text-slate-400 uppercase">Promedio Inst.</p><p class="text-3xl font-bold text-tup mt-1">—</p></div>
      <div class="bg-white rounded-2xl p-5 shadow-tarjeta"><p class="text-xs text-slate-400 uppercase">Sobresaliente</p><p class="text-3xl font-bold text-sobresaliente mt-1">—</p></div>
      <div class="bg-white rounded-2xl p-5 shadow-tarjeta"><p class="text-xs text-slate-400 uppercase">Focos Rojos</p><p class="text-3xl font-bold text-foco-rojo mt-1">—</p></div>
    </div>

    <div class="bg-white rounded-2xl shadow-tarjeta overflow-hidden">
      <div class="px-6 py-4 border-b"><h2 class="font-semibold text-slate-700">Docentes</h2></div>
      {filas.length === 0 ? (<div class="p-12 text-center text-slate-400">No hay docentes.</div>) : (
        <div class="overflow-x-auto"><table class="w-full text-sm"><thead><tr class="bg-slate-50 border-b"><th class="text-center px-4 py-3 text-xs uppercase">Docente</th><th class="text-center px-4 py-3 text-xs uppercase">Email</th><th class="text-center px-4 py-3 text-xs uppercase">Progreso</th></tr></thead>
        <tbody class="divide-y">{filas.map(d => (<tr class="hover:bg-slate-50"><td class="px-4 py-3 text-center font-medium">{d.nombre} {d.apellidos}</td><td class="px-4 py-3 text-center text-slate-600">{d.email}</td><td class="px-4 py-3 text-center"><span class="text-xs font-medium text-slate-600">{d.instrumentos}/5</span></td></tr>))}</tbody></table></div>
      )}
    </div>
  </div>
</LayoutAdmin>
