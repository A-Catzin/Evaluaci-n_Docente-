---
/**
 * Página: Dashboard Administrativo — SED-360
 *
 * Ruta: /admin/dashboard[?periodo=]
 *
 * Propósito: Panel principal para administradores, coordinadores y
 * calidad donde pueden visualizar el progreso de evaluaciones y los
 * resultados agregados 360° de todos los docentes.
 *
 * Protección:
 *   - El middleware (src/middleware.ts) ya valida que el usuario tenga
 *     rol admin, coordinador o calidad antes de llegar aquí.
 *   - La página verifica sesión via cookies.
 *
 * Flujo:
 *   1. Verifica sesión via cookies
 *   2. Obtiene el periodo activo (o el seleccionado via ?periodo=)
 *   3. Obtiene resultados agregados y progreso
 *   4. Obtiene nombres de docentes desde usuarios
 *   5. Renderiza tabla responsiva con puntajes coloreados
 */

import Layout from '../../layouts/Layout.astro';
import { obtenerPeriodoActivo, obtenerPeriodos } from '../../services/periodos';
import {
  obtenerResultadosPorPeriodo,
  calcularPuntajeGlobal360,
  obtenerProgresoEvaluacion,
} from '../../services/agregacion';
import { obtenerClienteSuperbase } from '../../lib/supabaseClient';
import type { Periodo, ResultadoAgregado } from '../../types/supabase';

// ─── Verificar sesión ─────────────────────────────────────────────

const tokenAcceso = Astro.cookies.get('sb-access-token')?.value;
const tokenRefresco = Astro.cookies.get('sb-refresh-token')?.value;

if (!tokenAcceso || !tokenRefresco) {
  return Astro.redirect('/auth');
}

const cliente = obtenerClienteSuperbase();
const { data: datosSesion, error: errorSesion } =
  await cliente.auth.setSession({
    access_token: tokenAcceso,
    refresh_token: tokenRefresco,
  });

if (errorSesion || !datosSesion?.user) {
  return Astro.redirect('/auth');
}

// ─── Obtener periodos ──────────────────────────────────────────────

let periodos: Periodo[] = [];
let periodoSeleccionado: Periodo | null = null;
let errorPeriodos: string | null = null;

try {
  periodos = await obtenerPeriodos();

  const idPeriodoParam = Astro.url.searchParams.get('periodo');
  if (idPeriodoParam) {
    periodoSeleccionado = periodos.find((p) => p.id_periodo === idPeriodoParam) ?? null;
  }

  if (!periodoSeleccionado) {
    periodoSeleccionado = await obtenerPeriodoActivo();
  }

  // Si no hay periodo activo, usar el primero disponible
  if (!periodoSeleccionado && periodos.length > 0) {
    periodoSeleccionado = periodos[0];
  }
} catch (e) {
  errorPeriodos =
    e instanceof Error
      ? e.message
      : 'Error al cargar los periodos. Intente nuevamente.';
}

const idPeriodo = periodoSeleccionado?.id_periodo;

// ─── Obtener resultados y progreso ─────────────────────────────────

let resultados: ResultadoAgregado[] = [];
let progreso = { totalCargas: 0, cargasEvaluadas: 0, porcentaje: 0 };
let errorDatos: string | null = null;
let emailPorDocente = new Map<string, string>();

if (idPeriodo) {
  try {
    resultados = await obtenerResultadosPorPeriodo(idPeriodo);
    progreso = await obtenerProgresoEvaluacion(idPeriodo);

    // Obtener emails de los docentes para mostrar nombre
    const idsDocentes = [...new Set(resultados.map((r) => r.id_docente))];
    if (idsDocentes.length > 0) {
      const { data: usuarios } = await cliente
        .from('usuarios')
        .select('id, email')
        .in('id', idsDocentes);

      if (usuarios) {
        emailPorDocente = new Map(usuarios.map((u) => [u.id, u.email]));
      }
    }
  } catch (e) {
    errorDatos =
      e instanceof Error
        ? e.message
        : 'Error al cargar los datos del dashboard.';
  }
}

// ─── Función helper para puntaje coloreado ────────────────────────

function clasePuntaje(puntaje: number): string {
  if (puntaje >= 80) return 'text-emerald-600';
  if (puntaje >= 50) return 'text-amber-600';
  return 'text-red-600';
}

function fondoPuntaje(puntaje: number): string {
  if (puntaje >= 80) return 'bg-emerald-50';
  if (puntaje >= 50) return 'bg-amber-50';
  return 'bg-red-50';
}

function nombreDocente(email: string): string {
  return email.split('@')[0].replace(/[._]/g, ' ');
}
---

<Layout titulo="Dashboard 360° — SED-360">
  <div class="animate-flotar-entrada">
    <!-- ═══ Header ═══ -->
    <header class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-institucional">
          Dashboard 360°
        </h1>
        <p class="text-slate-500 mt-1 text-sm sm:text-base">
          Resultados de evaluación docente
        </p>
      </div>

      <!-- Selector de periodo -->
      {
        periodos.length > 0 && (
          <form method="GET" class="flex items-center gap-2">
            <label for="periodo" class="text-sm text-slate-500 font-medium">
              Periodo:
            </label>
            <select
              id="periodo"
              name="periodo"
              class="rounded-xl border border-slate-200 bg-white px-4 py-2.5 text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-accion focus:border-accion shadow-tarjeta"
              onchange="this.form.submit()"
            >
              {
                periodos.map((p) => (
                  <option
                    value={p.id_periodo}
                    selected={p.id_periodo === idPeriodo}
                  >
                    {p.nombre}
                  </option>
                ))
              }
            </select>
          </form>
        )
      }
    </header>

    <!-- ═══ Error de periodos ═══ -->
    {
      errorPeriodos && (
        <div class="bg-red-50 border border-red-200 rounded-xl p-4 text-red-700 text-sm mb-6">
          <p>{errorPeriodos}</p>
        </div>
      )
    }

    <!-- ═══ Sin periodo disponible ═══ -->
    {
      !errorPeriodos && !idPeriodo && (
        <div class="flex flex-col items-center justify-center py-20 text-center">
          <div class="w-16 h-16 rounded-full bg-slate-100 flex items-center justify-center mb-5" aria-hidden="true">
            <svg class="w-8 h-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h2 class="text-lg font-semibold text-slate-600">
            No hay periodos disponibles
          </h2>
          <p class="text-slate-400 mt-2 max-w-sm text-sm">
            No se encontraron periodos académicos. Contacta al administrador del sistema.
          </p>
        </div>
      )
    }

    <!-- ═══ Contenido del dashboard ═══ -->
    {
      idPeriodo && (
        <>
          <!-- ═══ Tarjeta de progreso ═══ -->
          <div class="bg-white rounded-2xl p-6 shadow-tarjeta mb-6">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
              <div>
                <h2 class="text-lg font-semibold text-slate-700">
                  Progreso Global
                </h2>
                <p class="text-sm text-slate-500 mt-1">
                  {periodoSeleccionado?.nombre ?? idPeriodo}
                </p>
              </div>
              <div class="flex items-center gap-6">
                <div class="text-center">
                  <p class="text-3xl font-bold text-institucional">
                    {progreso.cargasEvaluadas}
                  </p>
                  <p class="text-xs text-slate-500 mt-0.5">Evaluadas</p>
                </div>
                <div class="text-slate-300 text-2xl font-light">/</div>
                <div class="text-center">
                  <p class="text-3xl font-bold text-slate-600">
                    {progreso.totalCargas}
                  </p>
                  <p class="text-xs text-slate-500 mt-0.5">Totales</p>
                </div>
                <div class="w-px h-12 bg-slate-200 hidden sm:block"></div>
                <div class="text-center">
                  <p class={`text-3xl font-bold ${
                    progreso.porcentaje >= 80 ? 'text-emerald-600' :
                    progreso.porcentaje >= 50 ? 'text-amber-600' :
                    'text-red-600'
                  }`}>
                    {progreso.porcentaje}%
                  </p>
                  <p class="text-xs text-slate-500 mt-0.5">Completado</p>
                </div>
              </div>
            </div>
            <!-- Barra de progreso -->
            <div class="mt-4 w-full h-2.5 bg-slate-100 rounded-full overflow-hidden">
              <div
                class={`h-full rounded-full transition-all duration-500 ${
                  progreso.porcentaje >= 80 ? 'bg-emerald-500' :
                  progreso.porcentaje >= 50 ? 'bg-amber-500' :
                  'bg-red-500'
                }`}
                style={`width: ${progreso.porcentaje}%`}
              ></div>
            </div>
          </div>

          <!-- ═══ Error de datos ═══ -->
          {
            errorDatos && (
              <div class="bg-red-50 border border-red-200 rounded-xl p-4 text-red-700 text-sm mb-6">
                <p>{errorDatos}</p>
              </div>
            )
          }

          <!-- ═══ Tabla de resultados ═══ -->
          {
            !errorDatos && resultados.length === 0 && (
              <div class="flex flex-col items-center justify-center py-20 text-center">
                <div class="w-16 h-16 rounded-full bg-slate-100 flex items-center justify-center mb-5" aria-hidden="true">
                  <svg class="w-8 h-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-3-3v6m-7 4h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <h2 class="text-lg font-semibold text-slate-600">
                  No hay evaluaciones registradas para este periodo
                </h2>
                <p class="text-slate-400 mt-2 max-w-sm text-sm">
                  Las evaluaciones aparecerán aquí una vez que los actores comiencen a evaluar.
                </p>
              </div>
            )
          }

          {
            !errorDatos && resultados.length > 0 && (
              <div class="bg-white rounded-2xl shadow-tarjeta overflow-hidden">
                <div class="overflow-x-auto">
                  <table class="w-full text-sm">
                    <thead>
                      <tr class="bg-slate-50 border-b border-slate-200">
                        <th class="text-left px-4 py-3.5 font-semibold text-slate-600 text-xs uppercase tracking-wider">
                          Docente
                        </th>
                        <th class="text-left px-4 py-3.5 font-semibold text-slate-600 text-xs uppercase tracking-wider">
                          Materia
                        </th>
                        <th class="text-center px-4 py-3.5 font-semibold text-slate-600 text-xs uppercase tracking-wider">
                          Puntaje Global 360°
                        </th>
                        <th class="text-center px-4 py-3.5 font-semibold text-slate-600 text-xs uppercase tracking-wider">
                          Progreso
                        </th>
                        <th class="text-right px-4 py-3.5 font-semibold text-slate-600 text-xs uppercase tracking-wider">
                          Acción
                        </th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                      {
                        resultados.map((r) => {
                          const puntaje = calcularPuntajeGlobal360(r);
                          const email = emailPorDocente.get(r.id_docente) ?? 'Sin email';
                          const actoresEvaluados = [
                            r.total_alumno > 0 ? 1 : 0,
                            r.total_coordinador > 0 ? 1 : 0,
                            r.total_tecnico > 0 ? 1 : 0,
                            r.total_calidad > 0 ? 1 : 0,
                            r.total_auto > 0 ? 1 : 0,
                          ].reduce((a, b) => a + b, 0);

                          return (
                            <tr class="hover:bg-slate-50 transition-colors">
                              <td class="px-4 py-3.5">
                                <div class="flex items-center gap-3">
                                  <div class="w-9 h-9 rounded-lg bg-hero-institucional flex items-center justify-center shadow-tarjeta flex-shrink-0">
                                    <span class="text-white font-bold text-xs">
                                      {nombreDocente(email).charAt(0).toUpperCase()}
                                    </span>
                                  </div>
                                  <div>
                                    <p class="font-medium text-slate-800">
                                      {nombreDocente(email)}
                                    </p>
                                    <p class="text-xs text-slate-400 truncate max-w-[180px]">
                                      {email}
                                    </p>
                                  </div>
                                </div>
                              </td>
                              <td class="px-4 py-3.5">
                                <span class="text-slate-700">{r.id_materia}</span>
                              </td>
                              <td class="px-4 py-3.5 text-center">
                                <span class={`inline-flex items-center justify-center w-16 h-10 rounded-xl font-bold text-sm ${fondoPuntaje(puntaje)} ${clasePuntaje(puntaje)}`}>
                                  {Math.round(puntaje)}
                                </span>
                              </td>
                              <td class="px-4 py-3.5 text-center">
                                <div class="flex items-center justify-center gap-1.5">
                                  <div class="flex gap-0.5">
                                    {[0, 1, 2, 3, 4].map((i) => (
                                      <div
                                        class={`w-2.5 h-2.5 rounded-full ${
                                          i < actoresEvaluados
                                            ? 'bg-emerald-500'
                                            : 'bg-slate-200'
                                        }`}
                                      ></div>
                                    ))}
                                  </div>
                                  <span class="text-xs text-slate-500 ml-1">
                                    {actoresEvaluados}/5
                                  </span>
                                </div>
                              </td>
                              <td class="px-4 py-3.5 text-right">
                                <a
                                  href={`/admin/dashboard/docente/${r.id_carga}`}
                                  class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-accion text-white text-xs font-medium hover:bg-accion/90 transition-colors shadow-tarjeta"
                                >
                                  Ver Detalle
                                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                                  </svg>
                                </a>
                              </td>
                            </tr>
                          );
                        })
                      }
                    </tbody>
                  </table>
                </div>
              </div>
            )
          }
        </>
      )
    }
  </div>
</Layout>
