---
import LayoutAdmin from '../../layouts/LayoutAdmin.astro';
import { obtenerCuatrimestres, obtenerCuatrimestreActivo } from '../../services/catalogos';
import { obtenerDocentes } from '../../services/docentes';
import { obtenerCalificacionesPorCuatrimestre } from '../../services/calificaciones';

const cuatrimestre = await obtenerCuatrimestreActivo();
const cuatrimestres = await obtenerCuatrimestres();
const idSeleccionado = Astro.url.searchParams.get('cuatrimestre') || cuatrimestre?.id?.toString() || '';
const docentes = await obtenerDocentes();
const calificaciones = idSeleccionado ? await obtenerCalificacionesPorCuatrimestre(parseInt(idSeleccionado)).catch(() => []) : [];

const totalDocentes = docentes.length;
const totalEvaluados = calificaciones.length;
const promedioInst = calificaciones.length > 0
  ? Math.round(calificaciones.reduce((s, c) => s + (c.calificacion_final || 0), 0) / calificaciones.length)
  : 0;
const sobresalientes = calificaciones.filter(c => c.categoria_final === 'Sobresaliente').length;

const cuatrimestreSel = cuatrimestres.find(c => c.id.toString() === idSeleccionado) || cuatrimestre;
---

<LayoutAdmin titulo="Dashboard — Admin">
  <div class="animate-flotar-entrada">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-3xl font-bold text-tup">Dashboard Administrativo</h1>
        <p class="text-slate-500">{cuatrimestreSel?.nombre || 'Sin cuatrimestre activo'}</p>
      </div>
      <form method="GET" class="flex items-center gap-2">
        <select name="cuatrimestre" class="rounded-xl border border-slate-200 px-3 py-2 text-sm" onchange="this.form.submit()">
          {cuatrimestres.map(c => (
            <option value={c.id} selected={c.id.toString() === idSeleccionado}>{c.nombre}</option>
          ))}
        </select>
      </form>
    </div>

    <!-- KPIs -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
      <div class="bg-white rounded-2xl p-5 shadow-tarjeta">
        <p class="text-xs text-slate-400 uppercase tracking-wider">Docentes</p>
        <p class="text-3xl font-bold text-tup mt-1">{totalDocentes}</p>
        <p class="text-xs text-slate-400 mt-1">{totalEvaluados} evaluados</p>
      </div>
      <div class="bg-white rounded-2xl p-5 shadow-tarjeta">
        <p class="text-xs text-slate-400 uppercase tracking-wider">Promedio Inst.</p>
        <p class="text-3xl font-bold text-tup mt-1">{promedioInst || '—'}</p>
      </div>
      <div class="bg-white rounded-2xl p-5 shadow-tarjeta">
        <p class="text-xs text-slate-400 uppercase tracking-wider">Sobresaliente</p>
        <p class="text-3xl font-bold text-sobresaliente mt-1">{sobresalientes || '—'}</p>
      </div>
      <div class="bg-white rounded-2xl p-5 shadow-tarjeta">
        <p class="text-xs text-slate-400 uppercase tracking-wider">Focos Rojos</p>
        <p class="text-3xl font-bold text-foco-rojo mt-1">{calificaciones.filter(c => c.tiene_comentarios_foco_rojo).length || '—'}</p>
      </div>
    </div>

    <!-- Tabla de Docentes -->
    <div class="bg-white rounded-2xl shadow-tarjeta overflow-hidden">
      <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
        <h2 class="font-semibold text-slate-700">Docentes</h2>
        <a href="/admin/docentes" class="text-sm text-tup hover:underline">Ver todos →</a>
      </div>
      {docentes.length === 0 ? (
        <div class="p-12 text-center text-slate-400">
          <p class="text-lg">No hay docentes registrados</p>
          <p class="text-sm mt-1">Agrega docentes desde la sección de administración</p>
        </div>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-slate-50 border-b border-slate-200">
                <th class="text-left px-4 py-3 font-semibold text-slate-600 text-xs uppercase">Docente</th>
                <th class="text-left px-4 py-3 font-semibold text-slate-600 text-xs uppercase">Email</th>
                <th class="text-center px-4 py-3 font-semibold text-slate-600 text-xs uppercase">Calificación</th>
                <th class="text-center px-4 py-3 font-semibold text-slate-600 text-xs uppercase">Instrumentos</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              {docentes.map(doc => {
                const cal = calificaciones.find(c => c.docente_id === doc.id);
                return (
                  <tr class="hover:bg-slate-50 transition-colors">
                    <td class="px-4 py-3">
                      <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-lg bg-hero-tup flex items-center justify-center text-white font-bold text-xs">{doc.nombre.charAt(0)}{doc.apellidos.charAt(0)}</div>
                        <div>
                          <p class="font-medium text-slate-800">{doc.nombre} {doc.apellidos}</p>
                          <p class="text-xs text-slate-400">{doc.num_empleado || '—'}</p>
                        </div>
                      </div>
                    </td>
                    <td class="px-4 py-3 text-slate-600">{doc.email}</td>
                    <td class="px-4 py-3 text-center">
                      {cal ? (
                        <span class="inline-flex items-center justify-center px-3 py-1 rounded-xl font-bold text-sm bg-tup/10 text-tup">{Math.round(cal.calificacion_final || 0)}</span>
                      ) : (
                        <span class="text-slate-400 text-xs">Sin evaluar</span>
                      )}
                    </td>
                    <td class="px-4 py-3 text-center">
                      <span class="text-xs text-slate-500">{cal?.num_instrumentos_completados || 0}/5</span>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </div>
</LayoutAdmin>
