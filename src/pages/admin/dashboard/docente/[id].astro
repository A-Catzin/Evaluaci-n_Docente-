---
/**
 * Página: Detalle Docente — Dashboard 360° (SED-360)
 *
 * Ruta: /admin/dashboard/docente/[id]
 *
 * Propósito: Mostrar el detalle completo de la evaluación 360° de
 * un docente para una carga académica específica. Incluye gráfico
 * radar, desglose de puntajes por actor y muro de comentarios.
 *
 * Protección:
 *   - El middleware (src/middleware.ts) ya valida que el usuario tenga
 *     rol admin, coordinador o calidad antes de llegar aquí.
 *   - La página verifica sesión via cookies.
 *
 * Flujo:
 *   1. Verifica sesión via cookies
 *   2. Obtiene resultado agregado para la carga
 *   3. Obtiene datos del docente y materia
 *   4. Obtiene comentarios anónimos
 *   5. Renderiza header, gráfico radar, tabla de desglose y muro
 */

import Layout from '../../../../layouts/Layout.astro';
import {
  calcularPuntajeGlobal360,
  obtenerComentariosAnonimos,
} from '../../../../services/agregacion';
import { obtenerClienteSuperbase } from '../../../../lib/supabaseClient';
import { PONDERACION_360, ETIQUETAS_ACTOR } from '../../../../types/supabase';
import type { ResultadoAgregado } from '../../../../types/supabase';

// ─── Verificar sesión ─────────────────────────────────────────────

const tokenAcceso = Astro.cookies.get('sb-access-token')?.value;
const tokenRefresco = Astro.cookies.get('sb-refresh-token')?.value;

if (!tokenAcceso || !tokenRefresco) {
  return Astro.redirect('/auth');
}

const cliente = obtenerClienteSuperbase();
const { data: datosSesion, error: errorSesion } =
  await cliente.auth.setSession({
    access_token: tokenAcceso,
    refresh_token: tokenRefresco,
  });

if (errorSesion || !datosSesion?.user) {
  return Astro.redirect('/auth');
}

// ─── Parámetro de ruta ────────────────────────────────────────────

const idCarga = parseInt(Astro.params.id ?? '', 10);
if (isNaN(idCarga) || idCarga <= 0) {
  return Astro.redirect('/admin/dashboard');
}

// ─── Obtener resultado agregado ───────────────────────────────────

let resultado: ResultadoAgregado | null = null;
let errorResultado: string | null = null;

try {
  const { data, error } = await cliente
    .from('resultados_agregados')
    .select('*')
    .eq('id_carga', idCarga)
    .single();

  if (error) {
    throw error;
  }

  resultado = data as ResultadoAgregado;
} catch (e) {
  errorResultado =
    e instanceof Error
      ? e.message
      : 'Error al obtener los resultados de la evaluación.';
}

// ─── Obtener datos del docente y materia ──────────────────────────

let nombreDocente = 'Docente';
let materia = 'Sin materia';
let periodo = '';

if (resultado) {
  // Obtener email del docente
  const { data: docente } = await cliente
    .from('usuarios')
    .select('email')
    .eq('id', resultado.id_docente)
    .single();

  if (docente?.email) {
    nombreDocente = docente.email.split('@')[0].replace(/[._]/g, ' ');
  }

  materia = resultado.id_materia;
  periodo = resultado.id_periodo;
}

// ─── Obtener comentarios anónimos ──────────────────────────────────

let comentarios: string[] = [];
let errorComentarios: string | null = null;

try {
  comentarios = await obtenerComentariosAnonimos(idCarga);
} catch (e) {
  errorComentarios =
    e instanceof Error ? e.message : 'Error al obtener comentarios.';
}

// ─── Calcular puntaje global ──────────────────────────────────────

const puntajeGlobal = resultado ? calcularPuntajeGlobal360(resultado) : 0;

// ─── Datos para el gráfico radar ─────────────────────────────────

interface DatoActor {
  actor: string;
  etiqueta: string;
  promedio: number;
  total: number;
  peso: number;
}

const actores: DatoActor[] = [
  {
    actor: 'ALUMNO',
    etiqueta: ETIQUETAS_ACTOR.ALUMNO,
    promedio: resultado?.promedio_alumno ?? 0,
    total: resultado?.total_alumno ?? 0,
    peso: PONDERACION_360.ALUMNO,
  },
  {
    actor: 'COORDINADOR',
    etiqueta: ETIQUETAS_ACTOR.COORDINADOR,
    promedio: resultado?.promedio_coordinador ?? 0,
    total: resultado?.total_coordinador ?? 0,
    peso: PONDERACION_360.COORDINADOR,
  },
  {
    actor: 'TECNICO',
    etiqueta: ETIQUETAS_ACTOR.TECNICO,
    promedio: resultado?.promedio_tecnico ?? 0,
    total: resultado?.total_tecnico ?? 0,
    peso: PONDERACION_360.TECNICO,
  },
  {
    actor: 'CALIDAD',
    etiqueta: ETIQUETAS_ACTOR.CALIDAD,
    promedio: resultado?.promedio_calidad ?? 0,
    total: resultado?.total_calidad ?? 0,
    peso: PONDERACION_360.CALIDAD,
  },
  {
    actor: 'AUTO',
    etiqueta: ETIQUETAS_ACTOR.AUTO,
    promedio: resultado?.promedio_auto ?? 0,
    total: resultado?.total_auto ?? 0,
    peso: PONDERACION_360.AUTO,
  },
];

const labelsRadar = JSON.stringify(actores.map((a) => a.etiqueta));
const datosRadar = JSON.stringify(actores.map((a) => a.promedio));

// ─── Clases de color para puntaje ─────────────────────────────────

function clasePuntaje(p: number): string {
  if (p >= 80) return 'text-emerald-600';
  if (p >= 50) return 'text-amber-600';
  return 'text-red-600';
}

function fondoPuntaje(p: number): string {
  if (p >= 80) return 'bg-emerald-50 border-emerald-200';
  if (p >= 50) return 'bg-amber-50 border-amber-200';
  return 'bg-red-50 border-red-200';
}
---

<Layout titulo={`${nombreDocente} — Detalle 360°`}>
  <div class="animate-flotar-entrada">
    <!-- ═══ Navegación ═══ -->
    <nav class="mb-6">
      <a
        href="/admin/dashboard"
        class="inline-flex items-center gap-1.5 text-sm text-slate-500 hover:text-institucional transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5m7-7l-7 7 7 7" />
        </svg>
        Volver al Dashboard
      </a>
    </nav>

    <!-- ═══ Error ═══ -->
    {
      errorResultado && (
        <div class="bg-red-50 border border-red-200 rounded-xl p-4 text-red-700 text-sm mb-6">
          <p>{errorResultado}</p>
        </div>
      )
    }

    <!-- ═══ Sin datos ═══ -->
    {
      !errorResultado && !resultado && (
        <div class="flex flex-col items-center justify-center py-20 text-center">
          <div class="w-16 h-16 rounded-full bg-slate-100 flex items-center justify-center mb-5" aria-hidden="true">
            <svg class="w-8 h-8 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-3-3v6m-7 4h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h2 class="text-lg font-semibold text-slate-600">
            Carga académica no encontrada
          </h2>
          <p class="text-slate-400 mt-2 max-w-sm text-sm">
            No se encontraron resultados para esta carga académica.
          </p>
        </div>
      )
    }

    <!-- ═══ Contenido del detalle ═══ -->
    {
      resultado && (
        <>
          <!-- ═══ Header: datos del docente ═══ -->
          <div class="bg-white rounded-2xl p-6 sm:p-8 shadow-tarjeta mb-6">
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
              <div>
                <div class="flex items-center gap-4 mb-2">
                  <div class="w-14 h-14 rounded-xl bg-hero-institucional flex items-center justify-center shadow-tarjeta">
                    <span class="text-white font-bold text-xl">
                      {nombreDocente.charAt(0).toUpperCase()}
                    </span>
                  </div>
                  <div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-institucional">
                      {nombreDocente}
                    </h1>
                    <p class="text-slate-500 text-sm mt-0.5">
                      {materia}
                    </p>
                    <p class="text-slate-400 text-xs mt-0.5">
                      Periodo {periodo}
                    </p>
                  </div>
                </div>
              </div>

              <!-- Puntaje Global 360° -->
              <div class={`flex flex-col items-center p-5 rounded-2xl border-2 ${fondoPuntaje(puntajeGlobal)}`}>
                <span class="text-xs font-medium text-slate-500 uppercase tracking-wider mb-1">
                  Puntaje Global 360°
                </span>
                <span class={`text-4xl sm:text-5xl font-bold ${clasePuntaje(puntajeGlobal)}`}>
                  {Math.round(puntajeGlobal)}
                </span>
                <span class="text-xs text-slate-400 mt-0.5">/ 100</span>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
            <!-- ═══ Gráfico Radar ═══ -->
            <div class="bg-white rounded-2xl p-6 shadow-tarjeta">
              <h2 class="text-lg font-semibold text-slate-700 mb-4">
                Desempeño por Actor
              </h2>
              <div class="relative max-w-sm mx-auto">
                <canvas id="radar-chart" width="300" height="300" data-labels='{labelsRadar}' data-datos='{datosRadar}'></canvas>
              </div>
            </div>

            <!-- ═══ Tabla de desglose ═══ -->
            <div class="bg-white rounded-2xl p-6 shadow-tarjeta">
              <h2 class="text-lg font-semibold text-slate-700 mb-4">
                Desglose de Evaluaciones
              </h2>
              <div class="overflow-hidden rounded-xl border border-slate-200">
                <table class="w-full text-sm">
                  <thead>
                    <tr class="bg-slate-50">
                      <th class="text-left px-4 py-3 font-semibold text-slate-600 text-xs uppercase tracking-wider">
                        Actor
                      </th>
                      <th class="text-center px-4 py-3 font-semibold text-slate-600 text-xs uppercase tracking-wider">
                        Promedio
                      </th>
                      <th class="text-center px-4 py-3 font-semibold text-slate-600 text-xs uppercase tracking-wider">
                        Total
                      </th>
                      <th class="text-center px-4 py-3 font-semibold text-slate-600 text-xs uppercase tracking-wider">
                        Peso
                      </th>
                    </tr>
                  </thead>
                  <tbody class="divide-y divide-slate-100">
                    {
                      actores.map((a) => (
                        <tr class="hover:bg-slate-50 transition-colors">
                          <td class="px-4 py-3">
                            <span class="text-slate-700 font-medium">{a.etiqueta}</span>
                          </td>
                          <td class="px-4 py-3 text-center">
                            <span class={`font-semibold ${a.promedio > 0 ? clasePuntaje(a.promedio) : 'text-slate-400'}`}>
                              {a.promedio > 0 ? Math.round(a.promedio) : '—'}
                            </span>
                          </td>
                          <td class="px-4 py-3 text-center text-slate-600">
                            {a.total > 0 ? a.total : '—'}
                          </td>
                          <td class="px-4 py-3 text-center">
                            <span class="inline-flex items-center justify-center px-2 py-1 rounded-lg bg-slate-100 text-slate-600 text-xs font-medium">
                              {(a.peso * 100).toFixed(0)}%
                            </span>
                          </td>
                        </tr>
                      ))
                    }
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- ═══ Muro de Comentarios ═══ -->
          <div class="bg-white rounded-2xl p-6 shadow-tarjeta">
            <h2 class="text-lg font-semibold text-slate-700 mb-4">
              Comentarios Anónimos
              {
                comentarios.length > 0 && (
                  <span class="text-sm font-normal text-slate-400 ml-2">
                    ({comentarios.length})
                  </span>
                )
              }
            </h2>

            {
              errorComentarios && (
                <p class="text-red-600 text-sm">{errorComentarios}</p>
              )
            }

            {
              !errorComentarios && comentarios.length === 0 && (
                <div class="flex flex-col items-center justify-center py-12 text-center">
                  <div class="w-12 h-12 rounded-full bg-slate-100 flex items-center justify-center mb-3" aria-hidden="true">
                    <svg class="w-6 h-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                    </svg>
                  </div>
                  <p class="text-slate-500 text-sm">
                    No hay comentarios para esta evaluación.
                  </p>
                </div>
              )
            }

            {
              comentarios.length > 0 && (
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  {
                    comentarios.map((comentario) => (
                      <div
                        class="p-4 rounded-xl bg-slate-50 border border-slate-100"
                      >
                        <p class="text-sm text-slate-700 leading-relaxed italic">
                          &ldquo;{comentario}&rdquo;
                        </p>
                      </div>
                    ))
                  }
                </div>
              )
            }
          </div>
        </>
      )
    }
  </div>
</Layout>

<!-- ═══ Chart.js CDN + Inicialización Radar ═══ -->
<script is:inline>
  (function () {
    var script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/chart.js';
    script.onload = iniciarGrafico;
    script.onerror = function () {
      console.error('[SED-360] Error al cargar Chart.js');
    };
    document.head.appendChild(script);

    function iniciarGrafico() {
      var canvas = document.getElementById('radar-chart');
      if (!canvas) return;

      var labels, datos;
      try {
        labels = JSON.parse(canvas.dataset.labels);
        datos = JSON.parse(canvas.dataset.datos).map(function (v) { return v || 0; });
      } catch (e) {
        console.error('[SED-360] Error al parsear datos del gráfico:', e);
        return;
      }

      new Chart(canvas, {
        type: 'radar',
        data: {
          labels: labels,
          datasets: [
            {
              label: 'Puntaje Promedio',
              data: datos,
              backgroundColor: 'rgba(27, 57, 106, 0.15)',
              borderColor: '#1B396A',
              borderWidth: 2,
              pointBackgroundColor: [
                '#2563EB',
                '#059669',
                '#D97706',
                '#DC2626',
                '#8B5CF6',
              ],
              pointBorderColor: '#fff',
              pointBorderWidth: 2,
              pointRadius: 5,
              pointHoverRadius: 7,
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          scales: {
            r: {
              beginAtZero: true,
              max: 100,
              ticks: {
                stepSize: 20,
                font: { size: 11 },
                backdropColor: 'transparent',
              },
              grid: {
                color: 'rgba(27, 57, 106, 0.08)',
              },
              angleLines: {
                color: 'rgba(27, 57, 106, 0.08)',
              },
              pointLabels: {
                font: { size: 12, weight: '500' },
                color: '#475569',
              },
            },
          },
          plugins: {
            legend: { display: false },
            tooltip: {
              callbacks: {
                label: function (context) {
                  return context.parsed.r !== null
                    ? context.parsed.r.toFixed(1) + ' / 100'
                    : 'Sin datos';
                },
              },
            },
          },
        },
      });
    }
  })();
</script>
