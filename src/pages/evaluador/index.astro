---
/**
 * Página: Mis Evaluaciones — Dashboard del Evaluador (SED-360)
 *
 * Propósito: Mostrar al evaluador todas sus cargas académicas del
 * periodo actual, indicando cuáles ya fueron evaluadas y cuáles
 * están pendientes.
 *
 * Protección:
 *   - El middleware (src/middleware.ts) ya valida sesión y dominio
 *     institucional antes de llegar aquí.
 *   - Adicionalmente, la página verifica las cookies de sesión para
 *     obtener el ID del usuario autenticado.
 *
 * Flujo:
 *   1. Lee cookies sb-access-token y sb-refresh-token
 *   2. Establece sesión en Supabase
 *   3. Obtiene cargas del periodo con estado (pendiente/completado)
 *   4. Renderiza grid responsivo de tarjetas
 */

import Layout from '../../layouts/Layout.astro';
import { obtenerCargasConEstado } from '../../services/cargas';
import { obtenerClienteSuperbase } from '../../lib/supabaseClient';

// ─── Verificar sesión y obtener usuario ───────────────────────────

const tokenAcceso = Astro.cookies.get('sb-access-token')?.value;
const tokenRefresco = Astro.cookies.get('sb-refresh-token')?.value;

if (!tokenAcceso || !tokenRefresco) {
  return Astro.redirect('/auth');
}

const cliente = obtenerClienteSuperbase();
const { data: datosSesion, error: errorSesion } =
  await cliente.auth.setSession({
    access_token: tokenAcceso,
    refresh_token: tokenRefresco,
  });

if (errorSesion || !datosSesion.user) {
  return Astro.redirect('/auth');
}

const idEvaluador = datosSesion.user.id;

// ─── Parámetros ───────────────────────────────────────────────────

const periodo = Astro.url.searchParams.get('periodo') || '2025-1';

// ─── Carga de datos ──────────────────────────────────────────────

interface CargaConEstado {
  id_carga: number;
  id_docente: string;
  id_materia: string;
  id_periodo: string;
  estado: 'pendiente' | 'completado';
}

let cargas: CargaConEstado[] = [];
let errorCargas: string | null = null;

try {
  cargas = await obtenerCargasConEstado(periodo, idEvaluador);
} catch (e) {
  errorCargas =
    e instanceof Error
      ? e.message
      : 'Error al cargar las evaluaciones. Intente nuevamente.';
}
---

<Layout titulo="Mis Evaluaciones — SED-360">
  <div class="animate-flotar-entrada">
    <!-- ═══ Header ═══ -->
    <header class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl sm:text-3xl font-bold text-institucional">
          Mis Evaluaciones
        </h1>
        <p class="text-slate-500 mt-1 text-sm sm:text-base">
          Periodo <span class="font-semibold text-slate-700">{periodo}</span>
        </p>
      </div>
    </header>

    <!-- ═══ Error ═══ -->
    {
      errorCargas && (
        <div class="bg-red-50 border border-red-200 rounded-xl p-4 text-red-700 text-sm mb-6">
          <div class="flex items-center gap-2">
            <svg
              class="w-5 h-5 flex-shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <circle cx="12" cy="12" r="10" />
              <line x1="12" y1="8" x2="12" y2="12" />
              <line x1="12" y1="16" x2="12.01" y2="16" />
            </svg>
            <span>{errorCargas}</span>
          </div>
        </div>
      )
    }

    <!-- ═══ Vacío ═══ -->
    {
      !errorCargas && cargas.length === 0 && (
        <div class="flex flex-col items-center justify-center py-20 text-center">
          <div
            class="w-16 h-16 rounded-full bg-slate-100 flex items-center justify-center mb-5"
            aria-hidden="true"
          >
            <svg
              class="w-8 h-8 text-slate-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12h6m-3-3v6m-7 4h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              />
            </svg>
          </div>
          <h2 class="text-lg font-semibold text-slate-600">
            No tienes evaluaciones pendientes
          </h2>
          <p class="text-slate-400 mt-2 max-w-sm text-sm">
            En este periodo no tienes cargas académicas asignadas para
            evaluar. Si crees que esto es un error, contacta a tu
            coordinador.
          </p>
        </div>
      )
    }

    <!-- ═══ Grid de cargas ═══ -->
    {
      !errorCargas && cargas.length > 0 && (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
          {
            cargas.map((carga) =>
              carga.estado === 'pendiente' ? (
                <a
                  href={`/evaluador/evaluar/${carga.id_carga}`}
                  class="block group"
                >
                  <article class="relative rounded-xl border border-slate-200 bg-white p-5 shadow-tarjeta hover:shadow-tarjeta-hover hover:scale-105 transition-all duration-200 h-full">
                    <!-- Badge pendiente -->
                    <div class="mb-3">
                      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg bg-amber-50 text-amber-700 text-xs font-medium">
                        <span class="w-2 h-2 rounded-full bg-amber-500 animate-pulso-suave"></span>
                        Pendiente
                      </span>
                    </div>

                    <!-- Identificador de materia -->
                    <div class="flex items-start gap-3">
                      <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-hero-institucional flex items-center justify-center shadow-tarjeta" aria-hidden="true">
                        <span class="text-white font-bold text-sm">
                          {carga.id_materia.substring(0, 2).toUpperCase()}
                        </span>
                      </div>
                      <div class="flex-1 min-w-0">
                        <h3 class="font-semibold text-slate-800 truncate">
                          {carga.id_materia}
                        </h3>
                        <p class="text-xs text-slate-500 mt-0.5">
                          Carga #{carga.id_carga}
                        </p>
                      </div>
                    </div>

                    <!-- Botón de acción -->
                    <div class="mt-5">
                      <span class="block w-full text-center px-4 py-2.5 rounded-lg bg-accion text-white text-sm font-medium group-hover:bg-accion-700 transition-colors">
                        Iniciar Evaluación
                      </span>
                    </div>
                  </article>
                </a>
              ) : (
                <article class="relative rounded-xl border border-slate-200 bg-white p-5 opacity-60 select-none h-full">
                  <!-- Badge completado + check -->
                  <div class="flex items-start justify-between mb-3">
                    <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-lg bg-emerald-50 text-emerald-700 text-xs font-medium">
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                      Completado
                    </span>
                    <svg class="w-6 h-6 text-emerald-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>

                  <!-- Identificador de materia -->
                  <div class="flex items-start gap-3">
                    <div class="flex-shrink-0 w-10 h-10 rounded-lg bg-slate-200 flex items-center justify-center" aria-hidden="true">
                      <span class="text-slate-500 font-bold text-sm">
                        {carga.id_materia.substring(0, 2).toUpperCase()}
                      </span>
                    </div>
                    <div class="flex-1 min-w-0">
                      <h3 class="font-semibold text-slate-600 truncate">
                        {carga.id_materia}
                      </h3>
                      <p class="text-xs text-slate-400 mt-0.5">
                        Carga #{carga.id_carga}
                      </p>
                    </div>
                  </div>
                </article>
              )
            )
          }
        </div>
      )
    }
  </div>
</Layout>

<style>
  /* Elimina el subrayado por defecto de los enlaces */
  a {
    text-decoration: none;
  }
</style>
