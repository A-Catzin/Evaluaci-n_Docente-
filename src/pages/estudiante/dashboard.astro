---
import LayoutEstudiante from '../../layouts/LayoutEstudiante.astro';
---
<LayoutEstudiante titulo="Mis Encuestas — Estudiante">
  <div class="animate-flotar-entrada w-full max-w-lg text-center">
    <div class="bg-white rounded-3xl p-8 shadow-modal">
      <div class="w-16 h-16 mx-auto rounded-2xl bg-hero-tup flex items-center justify-center mb-6">
        <span class="text-white font-bold text-xl">📝</span>
      </div>
      <h1 class="text-2xl font-bold text-tup mb-2">Mis Encuestas</h1>
      <p class="text-slate-500 mb-6">Evalúa a tus docentes de forma anónima</p>
      <div class="bg-slate-50 rounded-xl p-4 text-sm text-slate-400">
        No tienes encuestas pendientes en este momento.
      </div>
    </div>
  </div>
</LayoutEstudiante>
