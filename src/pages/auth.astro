---
/**
 * Página de Autenticación — Plataforma SED-360
 *
 * Redirige al flujo OAuth de Google (Supabase).
 * Fase 1: Placeholder con botón de login.
 * Fase 2+: Integración real con Supabase Auth UI.
 */
import Layout from '../layouts/Layout.astro';
---

<Layout
  titulo="SED-360 — Iniciar Sesión"
  descripcion="Accede al Sistema de Evaluación Docente 360° con tu cuenta institucional"
  modoEnfoque={true}
>
  <div class="flex flex-col items-center justify-center min-h-[80vh] gap-8">
    <!-- Tarjeta de Login -->
    <div class="w-full max-w-md bg-white rounded-3xl shadow-modal p-8 sm:p-10 animate-flotar-entrada">
      <!-- Logo / Identidad -->
      <div class="text-center mb-8">
        <div class="w-16 h-16 mx-auto rounded-2xl bg-hero-institucional flex items-center justify-center shadow-tarjeta mb-4">
          <span class="text-white font-bold text-lg">360</span>
        </div>
        <h1 class="text-2xl font-bold text-institucional">
          Iniciar Sesión
        </h1>
        <p class="text-sm text-slate-500 mt-1">
          Usa tu cuenta institucional de Google
        </p>
      </div>

      <!-- Aviso de dominio -->
      <div class="mb-6 p-3 rounded-xl bg-blue-50 border border-blue-100">
        <p class="text-xs text-blue-700 flex items-start gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 mt-0.5 flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="16" x2="12" y2="12" />
            <line x1="12" y1="8" x2="12.01" y2="8" />
          </svg>
          <span>Solo se permiten cuentas con dominio <strong>@tecplayacar.edu.mx</strong></span>
        </p>
      </div>

      <!-- Botón de Google Auth -->
      <button
        id="btn-google"
        type="button"
        class="w-full flex items-center justify-center gap-3 px-6 py-4 rounded-2xl border border-slate-200 bg-white shadow-tarjeta text-slate-700 font-medium hover:shadow-tarjeta-hover hover:border-slate-300 hover:bg-gray-50 transition-all active:scale-[0.98]"
      >
        <svg class="w-5 h-5 flex-shrink-0" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
        </svg>
        <span id="btn-texto">Continuar con Google</span>
      </button>
    </div>
  </div>
</Layout>

<script>
  import { obtenerClienteSuperbase } from '../lib/supabaseClient';

  const boton = document.getElementById('btn-google') as HTMLButtonElement | null;
  const textoBoton = document.getElementById('btn-texto') as HTMLSpanElement | null;

  if (boton && textoBoton) {
    boton.addEventListener('click', async () => {
      // Estado de carga: deshabilitar botón mientras redirige
      boton.disabled = true;
      textoBoton.textContent = 'Redirigiendo...';
      boton.classList.add('opacity-60', 'cursor-not-allowed');

      try {
        const cliente = obtenerClienteSuperbase();
        await cliente.auth.signInWithOAuth({
          provider: 'google',
          options: {
            redirectTo: window.location.origin + '/api/auth/callback',
          },
        });
      } catch (err) {
        console.error('[SED-360 Auth] Error al iniciar OAuth:', err);
        // Restaurar botón en caso de error
        boton.disabled = false;
        textoBoton.textContent = 'Continuar con Google';
        boton.classList.remove('opacity-60', 'cursor-not-allowed');
      }
    });
  }
</script>
