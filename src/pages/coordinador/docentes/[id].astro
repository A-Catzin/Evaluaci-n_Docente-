---
import LayoutCoordinador from '../../../layouts/LayoutCoordinador.astro';
const { id } = Astro.params;
---
<LayoutCoordinador titulo={`Perfil Docente ${id}`}>
  <div class="animate-flotar-entrada"><h1 class="text-3xl font-bold text-tup mb-6">Perfil del Docente</h1><div class="bg-white rounded-2xl p-8 shadow-tarjeta text-center text-slate-400"><p>Detalle del docente ID: {id}</p></div></div>
</LayoutCoordinador>
