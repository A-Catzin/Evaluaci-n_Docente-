---
import LayoutCoordinador from '../../../layouts/LayoutCoordinador.astro';
---
<LayoutCoordinador titulo="Captura: Coordinación">
  <div class="animate-flotar-entrada max-w-2xl mx-auto">
    <h1 class="text-3xl font-bold text-tup mb-6">Evaluación por Coordinación</h1>
    <div class="bg-white rounded-2xl p-8 shadow-tarjeta text-center text-slate-400">
      <p class="text-lg">Formulario de captura</p>
      <p class="text-sm mt-1">Selecciona un docente y cuatrimestre para evaluar.</p>
    </div>
  </div>
</LayoutCoordinador>
