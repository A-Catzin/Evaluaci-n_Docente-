---
import LayoutCoordinador from '../../layouts/LayoutCoordinador.astro';
import { obtenerCuatrimestreActivo } from '../../services/catalogos';
import { obtenerDocentes } from '../../services/docentes';
import { obtenerClienteSuperbase } from '../../lib/supabaseClient';

const cuatrimestre = await obtenerCuatrimestreActivo();
const docentes = await obtenerDocentes();
const cliente = obtenerClienteSuperbase();

// Obtener observaciones, planeaciones y evaluaciones de coordinación
const { data: obsData } = await cliente.from('observaciones').select('docente_id');
const { data: planData } = await cliente.from('planeaciones').select('docente_id,estado');
const { data: coordData } = await cliente.from('evaluacion_coordinacion').select('docente_id');

const obsSet = new Set((obsData || []).map(o => o.docente_id));
const planPendiente = new Set((planData || []).filter(p => p.estado === 'Pendiente').map(p => p.docente_id));
const planEvaluada = new Set((planData || []).filter(p => p.estado !== 'Pendiente').map(p => p.docente_id));
const coordSet = new Set((coordData || []).map(c => c.docente_id));
const totalDocs = docentes.length;

interface EstadoDocente {
  docente: { id: number; nombre: string; apellidos: string; email: string; modalidad: string };
  observacion: 'pendiente' | 'completada';
  planeacion: 'pendiente' | 'completada' | 'no_aplica';
  coordinacion: 'pendiente' | 'completada';
  completo: boolean;
}

const estados: EstadoDocente[] = docentes.map(d => ({
  docente: { id: d.id, nombre: d.nombre, apellidos: d.apellidos, email: d.email, modalidad: d.modalidad || 'Escolarizado' },
  observacion: obsSet.has(d.id) ? 'completada' : 'pendiente',
  planeacion: planEvaluada.has(d.id) ? 'completada' : planPendiente.has(d.id) ? 'pendiente' : 'no_aplica',
  coordinacion: coordSet.has(d.id) ? 'completada' : 'pendiente',
  completo: obsSet.has(d.id) && (planEvaluada.has(d.id) || planPendiente.has(d.id)) && coordSet.has(d.id),
}));

const pendientesObs = estados.filter(e => e.observacion === 'pendiente').length;
const pendientesPlan = estados.filter(e => e.planeacion === 'pendiente').length;
const pendientesCoord = estados.filter(e => e.coordinacion === 'pendiente').length;
const completadosObs = estados.filter(e => e.observacion === 'completada').length;
const completadosPlan = estados.filter(e => e.planeacion === 'completada').length;
const faltantes = estados.filter(e => !e.completo);
const completados = estados.filter(e => e.completo);
---

<LayoutCoordinador titulo="Dashboard — Coordinador">
  <div class="animate-flotar-entrada">
    <h1 class="text-3xl font-bold text-tup mb-2">Panel de Coordinación</h1>
    <p class="text-slate-500 mb-6">{cuatrimestre?.nombre || 'Sin cuatrimestre activo'} · {totalDocs} docentes</p>

    <!-- KPIs -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 mb-8">
      <div class="bg-white rounded-2xl p-4 shadow-tarjeta text-center">
        <p class="text-[10px] text-slate-400 uppercase">CA Pend.</p>
        <p class="text-xl font-bold text-amber-600">{pendientesCoord}</p>
      </div>
      <div class="bg-white rounded-2xl p-4 shadow-tarjeta text-center">
        <p class="text-[10px] text-slate-400 uppercase">Obs. Pend.</p>
        <p class="text-xl font-bold text-amber-600">{pendientesObs}</p>
      </div>
      <div class="bg-white rounded-2xl p-4 shadow-tarjeta text-center">
        <p class="text-[10px] text-slate-400 uppercase">Plan. Pend.</p>
        <p class="text-xl font-bold text-amber-600">{pendientesPlan}</p>
      </div>
      <div class="bg-white rounded-2xl p-4 shadow-tarjeta text-center">
        <p class="text-[10px] text-slate-400 uppercase">CA Lista</p>
        <p class="text-xl font-bold text-emerald-600">{estados.filter(e => e.coordinacion === 'completada').length}</p>
      </div>
      <div class="bg-white rounded-2xl p-4 shadow-tarjeta text-center">
        <p class="text-[10px] text-slate-400 uppercase">Obs. Lista</p>
        <p class="text-xl font-bold text-emerald-600">{estados.filter(e => e.observacion === 'completada').length}</p>
      </div>
      <div class="bg-white rounded-2xl p-4 shadow-tarjeta text-center">
        <p class="text-[10px] text-slate-400 uppercase">Plan. Lista</p>
        <p class="text-xl font-bold text-emerald-600">{estados.filter(e => e.planeacion === 'completada').length}</p>
      </div>
    </div>

    <!-- Pendientes de evaluar -->
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-4">
        <span class="w-3 h-3 rounded-full bg-amber-500"></span>
        <h2 class="text-lg font-bold text-slate-700">Pendientes de Evaluar ({faltantes.length})</h2>
      </div>
      {faltantes.length === 0 ? (
        <div class="bg-white rounded-2xl p-8 text-center text-slate-400 shadow-tarjeta">¡Todos evaluados!</div>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {faltantes.map(e => (
            <div class="bg-white rounded-xl p-4 shadow-tarjeta border border-amber-100">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 rounded-lg bg-hero-tup flex items-center justify-center text-white font-bold">{e.docente.nombre.charAt(0)}</div>
                <div class="flex-1 min-w-0">
                  <p class="font-medium text-slate-800 text-sm truncate">{e.docente.nombre} {e.docente.apellidos}</p>
                  <p class="text-xs text-slate-400 truncate">{e.docente.email}</p>
                </div>
              </div>
              <div class="flex gap-1.5">
                {e.coordinacion === 'pendiente' ? (
                  <a href={`/coordinador/captura/coordinacion?docente_id=${e.docente.id}`} class="flex-1 text-center px-2 py-1.5 rounded-lg bg-purple-600 text-white text-[10px] font-medium hover:bg-purple-700">CA</a>
                ) : (
                  <span class="flex-1 text-center px-2 py-1.5 rounded-lg bg-emerald-50 text-emerald-700 text-[10px] font-medium">✅ CA</span>
                )}
                {e.observacion === 'pendiente' ? (
                  <a href={`/coordinador/captura/observacion${e.docente.modalidad.includes('Virtual') ? '-virtual' : e.docente.modalidad.includes('Ejecutivo') ? '-ejecutivo' : ''}?docente_id=${e.docente.id}`} class="flex-1 text-center px-2 py-1.5 rounded-lg bg-tup text-white text-[10px] font-medium hover:bg-tup/90">Obs.</a>
                ) : (
                  <span class="flex-1 text-center px-2 py-1.5 rounded-lg bg-emerald-50 text-emerald-700 text-[10px] font-medium">✅ Obs.</span>
                )}
                {e.planeacion === 'pendiente' ? (
                  <a href="/coordinador/planeaciones" class="flex-1 text-center px-2 py-1.5 rounded-lg bg-dorado text-white text-[10px] font-medium hover:bg-dorado/90">Plan.</a>
                ) : e.planeacion === 'no_aplica' ? (
                  <span class="flex-1 text-center px-2 py-1.5 rounded-lg bg-slate-100 text-slate-400 text-[10px] font-medium">—</span>
                ) : (
                  <span class="flex-1 text-center px-2 py-1.5 rounded-lg bg-emerald-50 text-emerald-700 text-[10px] font-medium">✅ Plan.</span>
                )}
              </div>
            </div>
          ))}
        </div>
      )}
    </div>

    <!-- Ya evaluados -->
    {completados.length > 0 && (
      <div>
        <div class="flex items-center gap-2 mb-4">
          <span class="w-3 h-3 rounded-full bg-emerald-500"></span>
          <h2 class="text-lg font-bold text-slate-700">Ya Evaluados ({completados.length})</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {completados.map(e => (
            <div class="bg-emerald-50/50 rounded-xl p-4 border border-emerald-100 opacity-80">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center text-emerald-700 font-bold">{e.docente.nombre.charAt(0)}</div>
                <div class="flex-1 min-w-0">
                  <p class="font-medium text-slate-700 text-sm truncate">{e.docente.nombre} {e.docente.apellidos}</p>
                  <p class="text-xs text-slate-400">Completado</p>
                </div>
              </div>
              <div class="flex gap-2">
                <a href={`/coordinador/captura/observacion?docente_id=${e.docente.id}`} class="flex-1 text-center px-3 py-2 rounded-lg border border-emerald-200 text-emerald-700 text-xs font-medium hover:bg-emerald-100" onclick="return confirm('¿Querés editar la observación de este docente?')">✏️ Editar Obs.</a>
                <a href={`/coordinador/planeaciones`} class="flex-1 text-center px-3 py-2 rounded-lg border border-emerald-200 text-emerald-700 text-xs font-medium hover:bg-emerald-100">📋 Ver Plan.</a>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</LayoutCoordinador>
