---
import LayoutCoordinador from '../../layouts/LayoutCoordinador.astro';
---
<LayoutCoordinador titulo="Dashboard — Coordinador">
  <div class="animate-flotar-entrada">
    <h1 class="text-3xl font-bold text-tup mb-2">Panel de Coordinación</h1>
    <p class="text-slate-500 mb-8">Gestión de evaluaciones de tu área</p>
    <div class="bg-white rounded-2xl p-6 shadow-tarjeta text-center text-slate-400">
      <p class="text-lg">Dashboard del Coordinador</p>
      <p class="text-sm mt-1">Las evaluaciones de tu área aparecerán aquí.</p>
    </div>
  </div>
</LayoutCoordinador>
