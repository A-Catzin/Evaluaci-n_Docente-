---
import LayoutDocente from '../../layouts/LayoutDocente.astro';
import { obtenerClienteSuperbase } from '../../lib/supabaseClient';
import { obtenerCuatrimestreActivo, obtenerAsignaturas } from '../../services/catalogos';

const token = Astro.cookies.get('sb-access-token')?.value;
const refresh = Astro.cookies.get('sb-refresh-token')?.value;
if (!token || !refresh) return Astro.redirect('/auth');
const cl = obtenerClienteSuperbase();
const { data: sesion } = await cl.auth.setSession({ access_token: token, refresh_token: refresh });
if (!sesion.user) return Astro.redirect('/auth');
const { data: usuario } = await cl.from('usuarios').select('entidad_id,rol').eq('id', sesion.user.id).maybeSingle();
if (!usuario || usuario.rol !== 'docente' || !usuario.entidad_id) return Astro.redirect('/docente/dashboard');

const cuatrimestre = await obtenerCuatrimestreActivo();
const asignaturas = await obtenerAsignaturas();
const { data: docente } = await cl.from('docentes').select('campus,turno').eq('id', usuario.entidad_id).maybeSingle();
const { data: planeacionesRaw } = await cl.from('planeaciones').select('*, asignaturas!inner(nombre)').eq('docente_id', usuario.entidad_id).order('fecha_subida', { ascending: false });

interface PlaneacionItem { id: number; asignatura: string; grupo: string; estado: string; puntaje: number | null; url: string; }
const planeaciones: PlaneacionItem[] = [];
for (const p of (planeacionesRaw || [])) {
  const pdfUrl = (p as Record<string,unknown>).url_pdf as string;
  let urlFirmada = pdfUrl;
  try {
    const path = pdfUrl.split('/planeaciones/')[1];
    if (path) {
      const { data } = await cl.storage.from('planeaciones').createSignedUrl(path, 3600);
      if (data?.signedUrl) urlFirmada = data.signedUrl;
    }
  } catch {}
  planeaciones.push({
    id: (p as Record<string,unknown>).id as number,
    asignatura: ((p as Record<string,unknown>).asignaturas as {nombre:string})?.nombre || String((p as Record<string,unknown>).asignatura_id),
    grupo: (p as Record<string,unknown>).grupo as string,
    estado: (p as Record<string,unknown>).estado as string,
    puntaje: (p as Record<string,unknown>).puntaje_promedio as number | null,
    url: urlFirmada
  });
}
---

<LayoutDocente titulo="Mis Planeaciones">
  <div class="animate-flotar-entrada max-w-4xl mx-auto">
    <h1 class="text-3xl font-bold text-tup mb-2">Buzón de entrega Planeación Docente 26-3</h1>
    <p class="text-slate-500 mb-6">{cuatrimestre?.nombre || 'Sin cuatrimestre activo'}</p>

    <!-- Leyenda -->
    <div class="bg-white rounded-2xl p-6 shadow-tarjeta mb-8 text-sm text-slate-600 leading-relaxed space-y-3">
      <p class="font-medium text-tup">Estimado(a) docente:</p>
      <p>Una vez que haya cursado y acreditado el curso en Moodle <strong>"Formación Docente I"</strong>, en el cual se encuentra integrado el proceso para el uso del nuevo formato de Planeación Didáctica correspondiente al ciclo 26-2, deberá haber elaborado las planeaciones didácticas de cada una de las asignaturas y grupos a su cargo.</p>
      <p>Le invitamos a realizar el registro y la carga de sus planeaciones didácticas en este buzón electrónico, correspondiente al periodo académico vigente <strong>26-3</strong>. Este espacio ha sido habilitado para centralizar, resguardar y dar seguimiento institucional a las planeaciones, como parte del proceso de aseguramiento de la calidad educativa y del <strong>Sistema de Evaluación del Desempeño Docente 360</strong>.</p>
      <p>Es importante considerar que el registro y el proceso de envío deberán realizarse de manera individual por cada planeación, ya que el sistema se encuentra estructurado para recepcionar una planeación por registro. En el caso de asignaturas que se impartan a dos o más grupos, aun cuando el contenido sea el mismo, deberá elaborarse y enviarse una planeación didáctica por cada grupo.</p>
      <p>Cada archivo deberá corresponder claramente a la asignatura, grupo, modalidad y ciclo académico, a fin de garantizar el orden, la trazabilidad y la correcta validación académica.</p>
      <div class="bg-slate-50 rounded-xl p-4 text-xs font-mono">
        <p class="font-medium mb-1">Nomenclatura estandarizada:</p>
        <code>Asignatura_Grupo_Modalidad_ApellidoDocente_26-3.pdf</code>
        <p class="mt-1 text-slate-400">Ejemplo: <code>Fundamentos_Enfermeria_3A_Escolarizada_Perez_26-3.pdf</code></p>
      </div>
      <p>La fecha límite de entrega de las planeaciones será el <strong>16 de mayo (Docentes continuantes)</strong> y <strong>23 de mayo (Docentes de Nuevo Ingreso)</strong>, conforme al calendario académico vigente. Una vez concluida esta fecha, el proceso se considerará cerrado y se notificará a la Coordinación Académica correspondiente para el seguimiento institucional de su estatus.</p>
      <p>Por favor, asegúrese de completar correctamente la información solicitada y de adjuntar el archivo correspondiente conforme a los lineamientos establecidos.</p>
      <p class="font-medium text-slate-500">Agradecemos su colaboración, responsabilidad académica y compromiso con la mejora continua y la calidad educativa institucional.</p>
    </div>

    <!-- Formulario de subida -->
    <div class="bg-white rounded-2xl p-6 shadow-tarjeta mb-8">
      <h2 class="text-lg font-bold text-tup mb-4">Subir Nueva Planeación</h2>
      <form id="form-subir" class="space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div><label class="block text-sm font-medium text-slate-700 mb-1">Asignatura *</label><select id="asignatura_id" required class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm"><option value="">Seleccionar...</option>{asignaturas.map(a => (<option value={a.id}>{a.nombre}</option>))}</select></div>
          <div><label class="block text-sm font-medium text-slate-700 mb-1">Grupo *</label><input type="text" id="grupo" required placeholder="Ej: 3A" class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm" /></div>
          <div><label class="block text-sm font-medium text-slate-700 mb-1">Modalidad</label><select id="modalidad" class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm"><option>Escolarizada</option><option>Ejecutiva</option></select></div>
          <div><label class="block text-sm font-medium text-slate-700 mb-1">Archivo PDF *</label><input type="file" id="archivo" accept=".pdf" required class="w-full rounded-xl border border-slate-200 px-4 py-2.5 text-sm file:mr-3 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-tup file:text-white" /></div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div><label class="block text-sm font-medium text-slate-700 mb-1">¿Proyecto?</label><select id="proyecto" class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm"><option value="false">No</option><option value="true">Sí</option></select></div>
          <div><label class="block text-sm font-medium text-slate-700 mb-1">¿Laboratorio?</label><select id="laboratorio" class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm"><option>No aplica</option><option value="Si">Sí</option><option>No</option></select></div>
          <div><label class="block text-sm font-medium text-slate-700 mb-1">¿Visitas?</label><select id="visitas" class="w-full rounded-xl border border-slate-200 px-3 py-2.5 text-sm"><option>No aplica</option><option value="Si">Sí</option><option>No</option></select></div>
        </div>
        <textarea id="comentario" placeholder="Comentario (opcional)" rows={2} class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm resize-none"></textarea>
        <button type="submit" class="w-full bg-tup text-white font-semibold py-3 rounded-xl hover:bg-tup/90">Subir Planeación</button>
      </form>
    </div>

    <!-- Lista -->
    <div class="bg-white rounded-2xl shadow-tarjeta overflow-hidden">
      <div class="px-6 py-4 border-b"><h2 class="font-semibold text-slate-700">Planeaciones Enviadas ({planeaciones.length})</h2></div>
      {planeaciones.length === 0 ? (
        <div class="p-12 text-center text-slate-400">No has subido planeaciones todavía.</div>
      ) : (
        <table class="w-full text-sm"><thead><tr class="bg-slate-50 border-b"><th class="text-left px-4 py-3 text-xs uppercase">Asignatura</th><th class="text-left px-4 py-3 text-xs uppercase">Grupo</th><th class="text-center px-4 py-3 text-xs uppercase">Estado</th><th class="text-center px-4 py-3 text-xs uppercase">Puntaje</th><th class="text-right px-4 py-3 text-xs uppercase">PDF</th></tr></thead>
        <tbody class="divide-y">{planeaciones.map(p => (<tr class="hover:bg-slate-50"><td class="px-4 py-3">{p.asignatura}</td><td class="px-4 py-3">{p.grupo}</td><td class="px-4 py-3 text-center"><span class={`px-2 py-0.5 rounded-lg text-xs font-medium ${p.estado==='Aprobado'?'bg-emerald-50 text-emerald-700':p.estado==='Corrección'?'bg-red-50 text-red-700':'bg-amber-50 text-amber-700'}`}>{p.estado}</span></td><td class="px-4 py-3 text-center font-bold">{p.puntaje ? Math.round(p.puntaje)+'%' : '—'}</td><td class="px-4 py-3 text-right"><a href={p.url} target="_blank" class="text-tup text-xs hover:underline">Ver PDF</a></td></tr>))}</tbody></table>
      )}
    </div>
    <div id="toast" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 hidden px-6 py-3 rounded-xl text-sm font-medium shadow-modal"></div>
  </div>
</LayoutDocente>

<script is:inline define:vars={{ docenteId: usuario.entidad_id, cuatrimestreId: cuatrimestre?.id, campus: docente?.campus || '', turno: docente?.turno || '' }}>
  function toast(m,e){var t=document.getElementById('toast');t.textContent=m;t.className='fixed bottom-6 left-1/2 -translate-x-1/2 z-50 px-6 py-3 rounded-xl text-sm font-medium shadow-modal '+(e?'bg-red-600 text-white':'bg-emerald-600 text-white');t.classList.remove('hidden');setTimeout(function(){t.classList.add('hidden')},4000)}
  document.getElementById('form-subir').addEventListener('submit',async function(e){
    e.preventDefault();var btn=this.querySelector('button[type="submit"]');btn.disabled=true;btn.textContent='Subiendo...';
    var file=document.getElementById('archivo').files[0];
    if(!file){toast('Selecciona un archivo PDF',true);btn.disabled=false;btn.textContent='Subir Planeación';return}
    var asig=document.getElementById('asignatura_id');var grupo=document.getElementById('grupo').value.trim();
    var asigNombre=asig.options[asig.selectedIndex].text.replace(/\s+/g,'_');var nombreArchivo=asigNombre+'_'+grupo+'_doc_26-3.pdf';
    try{
      var path=cuatrimestreId+'/'+docenteId+'/'+Date.now()+'_'+file.name.replace(/\s+/g,'_');
      var formData=new FormData();
      formData.append('file',file); formData.append('path',path);
      formData.append('cuatrimestre',cuatrimestreId); formData.append('asignatura',asig.value);
      formData.append('grupo',grupo); formData.append('modalidad',document.getElementById('modalidad').value);
      formData.append('proyecto',document.getElementById('proyecto').value==='true'?'true':'false');
      formData.append('laboratorio',document.getElementById('laboratorio').value);
      formData.append('visitas',document.getElementById('visitas').value);
      formData.append('comentario',document.getElementById('comentario').value.trim()||'');
      formData.append('campus',campus); formData.append('turno',turno); formData.append('nombre',nombreArchivo);
      var uploadRes=await fetch('/api/docente/subir-archivo',{method:'POST',body:formData});
      if(!uploadRes.ok){var errData=await uploadRes.json().catch(function(){return{}});toast('Error: '+(errData.error||errData.message||uploadRes.status),true);btn.disabled=false;btn.textContent='Subir Planeación';return}
      toast('¡Planeación subida exitosamente!',false);setTimeout(function(){location.reload()},1000);
    }catch(err){toast('Error: '+err.message,true);btn.disabled=false;btn.textContent='Subir Planeación'}
  });
</script>
