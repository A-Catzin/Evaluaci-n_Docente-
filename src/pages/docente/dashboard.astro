---
import LayoutDocente from '../../layouts/LayoutDocente.astro';
---
<LayoutDocente titulo="Mi Evaluación — Docente">
  <div class="animate-flotar-entrada">
    <h1 class="text-3xl font-bold text-tup mb-2">Mi Evaluación</h1>
    <p class="text-slate-500 mb-8">Resultados de tu desempeño docente</p>
    <div class="bg-white rounded-2xl p-6 shadow-tarjeta text-center text-slate-400">
      <p class="text-lg">Tus resultados aparecerán aquí</p>
      <p class="text-sm mt-1">Cuando el cuatrimestre esté cerrado podrás ver tu calificación.</p>
    </div>
  </div>
</LayoutDocente>
