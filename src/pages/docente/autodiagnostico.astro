---
import LayoutDocente from '../../layouts/LayoutDocente.astro';
import { obtenerCuatrimestreActivo, obtenerOfertasAcademicas } from '../../services/catalogos';
import { obtenerAutodiagnostico } from '../../services/autodiagnostico';
import { obtenerClienteSuperbase } from '../../lib/supabaseClient';

const tokenAcceso = Astro.cookies.get('sb-access-token')?.value;
const tokenRefresco = Astro.cookies.get('sb-refresh-token')?.value;
if (!tokenAcceso || !tokenRefresco) return Astro.redirect('/auth');

const cliente = obtenerClienteSuperbase();
const { data: sesion } = await cliente.auth.setSession({ access_token: tokenAcceso, refresh_token: tokenRefresco });
if (!sesion.user) return Astro.redirect('/auth');

const { data: usuario } = await cliente.from('usuarios').select('entidad_id,rol').eq('id', sesion.user.id).maybeSingle();
if (!usuario || usuario.rol !== 'docente') return Astro.redirect('/docente/dashboard');
const docenteId = usuario.entidad_id;

const cuatrimestre = await obtenerCuatrimestreActivo();
if (!cuatrimestre) return Astro.redirect('/docente/dashboard');

const existente = docenteId ? await obtenerAutodiagnostico(docenteId, cuatrimestre.id) : null;
const yaRespondido = !!existente;

const ofertas = await obtenerOfertasAcademicas();
const OFERTA = ofertas.map(o => o.nombre);
const TURNOS = ['Matutino','Vespertino','Mixto','Virtual'];
const CAMPUS = ['Tecnológico Universitario Tuxtla','Tecnológico Universitario Playacar / Facultad de Ciencias de la Salud'];
const REACTIVOS = [
  'Domino los conceptos para la construcción del aprendizaje en los cursos o programas académicos que imparto.',
  'Expongo, organizo, desarrollo y vinculo los contenidos en forma clara.',
  'Adapto los contenidos a los diversos estilos y necesidades de los estudiantes.',
  'Organizo espacios de reflexión antes, durante y después de las actividades de aprendizaje.',
  'Incluyo actividades en clase que promueven el aprendizaje autónomo en los estudiantes.',
  'Propongo ejercicios para promover la metacognición en su ambiente de aprendizaje.',
  'Propongo nuevas estrategias para mejorar los resultados obtenidos en el desempeño de los estudiantes.',
  'Me comunico con claridad y precisión.',
  'Escucho activamente a mis estudiantes.',
  'Fomento la participación y el diálogo respetuoso.',
  'Mantengo un trato respetuoso con mis estudiantes.',
  'Atiendo situaciones grupales con sensibilidad y objetividad.',
  'Organizo los objetivos y contenidos de manera coherente con el modelo educativo.',
  'Implemento diversas estrategias para inducir el aprendizaje significativo.',
  'Considero saberes previos, intereses y experiencias de sus estudiantes.',
  'Genero oportunidades de desarrollo del pensamiento crítico y creativo.',
  'Motivo al aprendizaje, la indagación y la búsqueda de conocimiento.',
  'Ofrezco retroalimentación oportuna, pertinente y cálida a los estudiantes.',
  'Promuevo un ambiente de confianza y respeto.',
  'Manejo mis emociones de forma profesional en clase.',
  'Utilizo herramientas tecnológicas para enriquecer mi enseñanza.',
  'Integro recursos digitales de forma adecuada a los contenidos.',
  'Conozco y aplico la normatividad institucional.',
  'Respeto el reglamento y lineamientos académicos.',
];
---

<LayoutDocente titulo="Autodiagnóstico Docente">
  <div class="animate-flotar-entrada max-w-3xl mx-auto">
    <h1 class="text-3xl font-bold text-tup mb-2">Autodiagnóstico Docente</h1>
    <p class="text-slate-500 mb-2">Cuatrimestre {cuatrimestre.nombre}</p>

    {yaRespondido ? (
      <div class="bg-emerald-50 border border-emerald-200 rounded-2xl p-8 text-center">
        <p class="text-emerald-800 font-semibold text-lg">✅ Ya completaste tu autodiagnóstico</p>
        <p class="text-emerald-600 text-sm mt-2">No es posible enviarlo nuevamente para este cuatrimestre.</p>
        <a href="/docente/dashboard" class="inline-block mt-4 px-6 py-2.5 rounded-xl bg-tup text-white text-sm font-medium">Volver al Dashboard</a>
      </div>
    ) : (
      <>
        <!-- Barra de progreso -->
        <div class="bg-white rounded-2xl p-4 shadow-tarjeta mb-6">
          <div class="flex justify-between text-xs text-slate-400 mb-2">
            <span id="paso-label">Paso 1 de 4</span><span id="porcentaje-label">25%</span>
          </div>
          <div class="w-full h-2 bg-slate-100 rounded-full overflow-hidden">
            <div id="barra-progreso" class="h-full bg-tup rounded-full transition-all duration-300" style="width:25%"></div>
          </div>
        </div>

        <form id="form-autodiagnostico" class="space-y-6">
          <!-- PASO 1: Identificación -->
          <div id="paso-1" class="paso bg-white rounded-2xl p-6 sm:p-8 shadow-tarjeta">
            <h2 class="text-xl font-bold text-tup mb-1">Información Personal</h2>
            <p class="text-xs text-slate-400 mb-6">Completa tus datos de identificación</p>
            <div class="space-y-4">
              <div><label class="block text-sm font-medium text-slate-700 mb-1">Nombre(s) *</label><input type="text" id="nombre" required class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm focus:ring-2 focus:ring-tup focus:outline-none" /></div>
              <div class="grid grid-cols-2 gap-4">
                <div><label class="block text-sm font-medium text-slate-700 mb-1">Apellido Paterno *</label><input type="text" id="ap_paterno" required class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm focus:ring-2 focus:ring-tup focus:outline-none" /></div>
                <div><label class="block text-sm font-medium text-slate-700 mb-1">Apellido Materno *</label><input type="text" id="ap_materno" required class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm focus:ring-2 focus:ring-tup focus:outline-none" /></div>
              </div>
              <div>
                <label class="block text-sm font-medium text-slate-700 mb-2">Campus asignado *</label>
                <div class="space-y-2">
                  {CAMPUS.map(c => (<label class="flex items-center gap-3 p-3 rounded-xl border border-slate-200 hover:bg-tup/5 cursor-pointer"><input type="radio" name="campus" value={c} required class="accent-tup" /><span class="text-sm text-slate-700">{c}</span></label>))}
                </div>
              </div>
            </div>
          </div>

          <!-- PASO 2: Datos Académicos -->
          <div id="paso-2" class="paso hidden bg-white rounded-2xl p-6 sm:p-8 shadow-tarjeta">
            <h2 class="text-xl font-bold text-tup mb-1">Datos Académicos</h2>
            <p class="text-xs text-slate-400 mb-6">Selecciona tu oferta académica y turno</p>
            <div class="mb-6">
              <label class="block text-sm font-medium text-slate-700 mb-2">Oferta académica *</label>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                {OFERTA.map(o => (<label class="flex items-center gap-2 p-2 rounded-lg hover:bg-tup/5 cursor-pointer"><input type="checkbox" name="oferta" value={o} class="accent-tup" /><span class="text-sm text-slate-700">{o}</span></label>))}
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-2">Turno *</label>
              <div class="flex flex-wrap gap-2">
                {TURNOS.map(t => (<label class="flex items-center gap-2 px-4 py-2 rounded-xl border border-slate-200 hover:bg-tup/5 cursor-pointer"><input type="checkbox" name="turno" value={t} class="accent-tup" /><span class="text-sm text-slate-700">{t}</span></label>))}
              </div>
            </div>
          </div>

          <!-- PASO 3: Reactivos -->
          <div id="paso-3" class="paso hidden bg-white rounded-2xl p-6 sm:p-8 shadow-tarjeta">
            <h2 class="text-xl font-bold text-tup mb-1">Evaluación de Competencias</h2>
            <p class="text-xs text-slate-400 mb-1">Selecciona la opción más acorde</p>
            <p class="text-xs text-slate-300 mb-6">(5) Siempre &gt;90% · (4) Casi siempre 70-89% · (3) Algunas veces 50-69% · (2) Pocas veces 20-49% · (1) Nunca &lt;20%</p>
            <div class="space-y-5">
              {REACTIVOS.map((r, i) => (
                <div class="p-4 rounded-xl bg-slate-50">
                  <p class="text-sm font-medium text-slate-700 mb-3">{i+1}. {r}</p>
                  <div class="flex gap-2">
                    {[1,2,3,4,5].map(v => (
                      <label class={`flex-1 flex flex-col items-center gap-1 p-2 rounded-lg border-2 border-slate-200 hover:border-tup cursor-pointer transition-colors text-center reactivo-${i}`}>
                        <input type="radio" name={`r${i+1}`} value={v} required class="sr-only peer" />
                        <span class="text-lg font-bold text-slate-400 peer-checked:text-tup">{v}</span>
                        <span class="text-[9px] text-slate-400 peer-checked:text-tup leading-tight">{['Nunca','Pocas veces','Algunas veces','Casi siempre','Siempre'][v-1]}</span>
                      </label>
                    ))}
                  </div>
                </div>
              ))}
            </div>
          </div>

          <!-- PASO 4: Cierre -->
          <div id="paso-4" class="paso hidden bg-white rounded-2xl p-6 sm:p-8 shadow-tarjeta">
            <h2 class="text-xl font-bold text-tup mb-4">Comentarios Finales</h2>
            <p class="text-sm text-slate-600 mb-6 leading-relaxed">Agradecemos sinceramente el tiempo y la disposición que han dedicado al llenado del Autodiagnóstico Docente. Su participación refleja el compromiso con la reflexión profesional, la mejora continua y el fortalecimiento de la calidad educativa.</p>
            <label class="block text-sm font-medium text-slate-700 mb-1">Comentarios (opcional)</label>
            <textarea id="comentarios" rows={4} class="w-full rounded-xl border border-slate-200 px-4 py-3 text-sm focus:ring-2 focus:ring-tup focus:outline-none resize-none" placeholder="Escribe aquí tus reflexiones..."></textarea>
            <button type="submit" id="btn-enviar" class="mt-6 w-full bg-tup text-white font-semibold text-lg py-4 px-6 rounded-2xl shadow-tarjeta hover:bg-tup/90 transition-all">Enviar Autodiagnóstico</button>
          </div>
        </form>

        <!-- Navegación -->
        <div class="flex justify-between mt-6">
          <button id="btn-atras" class="px-6 py-3 rounded-xl border border-slate-200 text-slate-600 text-sm font-medium hover:bg-slate-50 transition-colors hidden">← Atrás</button>
          <button id="btn-siguiente" class="px-6 py-3 rounded-xl bg-tup text-white text-sm font-medium hover:bg-tup/90 transition-colors ml-auto">Siguiente →</button>
        </div>
      </>
    )}

    <!-- Modal de resultado -->
    <div id="modal-resultado" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 backdrop-blur-sm">
      <div class="bg-white rounded-3xl p-8 shadow-modal max-w-sm w-full mx-4 text-center animate-flotar-entrada">
        <div id="modal-icono" class="w-16 h-16 mx-auto rounded-full flex items-center justify-center mb-4"></div>
        <h3 id="modal-titulo" class="text-xl font-bold mb-2"></h3>
        <p id="modal-puntaje" class="text-4xl font-bold mb-1"></p>
        <p id="modal-nivel" class="text-sm font-medium mb-4"></p>
        <p id="modal-mensaje" class="text-sm text-slate-500 mb-6"></p>
        <a href="/docente/dashboard" class="inline-block px-6 py-3 rounded-xl bg-tup text-white font-medium">Volver al Dashboard</a>
      </div>
    </div>
  </div>
</LayoutDocente>

<script is:inline define:vars={{ cuatrimestreId: cuatrimestre.id }}>
  var pasoActual = 1;
  var totalPasos = 4;

  function mostrarPaso(n) {
    document.querySelectorAll('.paso').forEach(function (p) { p.classList.add('hidden'); });
    var el = document.getElementById('paso-' + n);
    if (el) el.classList.remove('hidden');
    document.getElementById('paso-label').textContent = 'Paso ' + n + ' de ' + totalPasos;
    var pct = Math.round((n / totalPasos) * 100);
    document.getElementById('porcentaje-label').textContent = pct + '%';
    document.getElementById('barra-progreso').style.width = pct + '%';
    document.getElementById('btn-atras').classList.toggle('hidden', n === 1);
    document.getElementById('btn-siguiente').classList.toggle('hidden', n === totalPasos);
    pasoActual = n;
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  function validarPaso(n) {
    if (n === 1) {
      var nombre = document.getElementById('nombre').value.trim();
      var ap = document.getElementById('ap_paterno').value.trim();
      var am = document.getElementById('ap_materno').value.trim();
      var campus = document.querySelector('input[name="campus"]:checked');
      if (!nombre || !ap || !am || !campus) { alert('Todos los campos de identificación son obligatorios.'); return false; }
    }
    if (n === 2) {
      var oferta = document.querySelectorAll('input[name="oferta"]:checked');
      var turno = document.querySelectorAll('input[name="turno"]:checked');
      if (oferta.length === 0) { alert('Selecciona al menos una oferta académica.'); return false; }
      if (turno.length === 0) { alert('Selecciona al menos un turno.'); return false; }
    }
    return true;
  }

  document.getElementById('btn-siguiente').addEventListener('click', function () {
    if (validarPaso(pasoActual)) mostrarPaso(pasoActual + 1);
  });
  document.getElementById('btn-atras').addEventListener('click', function () {
    mostrarPaso(pasoActual - 1);
  });

  // Radio button visual feedback para reactivos
  document.querySelectorAll('input[type="radio"][name^="r"]').forEach(function (rb) {
    rb.addEventListener('change', function () {
      var parent = this.closest('label');
      var group = parent.parentElement;
      group.querySelectorAll('label').forEach(function (l) {
        l.classList.remove('border-tup', 'bg-tup/5');
      });
      parent.classList.add('border-tup', 'bg-tup/5');
    });
  });

  // Enviar formulario
  document.getElementById('form-autodiagnostico').addEventListener('submit', async function (e) {
    e.preventDefault();
    var btn = document.getElementById('btn-enviar');
    btn.disabled = true;
    btn.textContent = 'Enviando...';

    var nombre = document.getElementById('nombre').value.trim();
    var campus = document.querySelector('input[name="campus"]:checked').value;
    var oferta = Array.from(document.querySelectorAll('input[name="oferta"]:checked')).map(function (c) { return c.value; }).join(', ');
    var turno = Array.from(document.querySelectorAll('input[name="turno"]:checked')).map(function (c) { return c.value; }).join(', ');
    var reactivos = [];
    for (var i = 1; i <= 24; i++) {
      var rb = document.querySelector('input[name="r' + i + '"]:checked');
      if (!rb) { alert('Responde todos los reactivos antes de enviar.'); btn.disabled = false; btn.textContent = 'Enviar Autodiagnóstico'; return; }
      reactivos.push(parseInt(rb.value));
    }

    try {
      var res = await fetch('/api/docente/autodiagnostico', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          cuatrimestre_id: cuatrimestreId,
          nombre: nombre,
          apellido_paterno: document.getElementById('ap_paterno').value.trim(),
          apellido_materno: document.getElementById('ap_materno').value.trim(),
          campus: campus,
          oferta_academica: oferta,
          turno: turno,
          reactivos: reactivos,
          comentarios: document.getElementById('comentarios').value.trim() || null,
        }),
      });
      var data = await res.json();
      if (res.ok) {
        mostrarModal(data);
      } else {
        alert(data.error || 'Error al enviar');
        btn.disabled = false;
        btn.textContent = 'Enviar Autodiagnóstico';
      }
    } catch (err) {
      alert('Error de conexión');
      btn.disabled = false;
      btn.textContent = 'Enviar Autodiagnóstico';
    }
  });

  function mostrarModal(data) {
    var modal = document.getElementById('modal-resultado');
    var niveles = { 'Excelente': ['✅','#22c55e','¡Felicitaciones! Tu desempeño es sobresaliente.','bg-emerald-50 text-emerald-700'],
      'Satisfactorio': ['👍','#3b82f6','Buen trabajo. Continúa con la mejora continua.','bg-blue-50 text-blue-700'],
      'En Desarrollo': ['📚','#f59e0b','Te sugerimos capacitación pedagógica para fortalecer tu práctica.','bg-amber-50 text-amber-700'],
      'Necesita Mejora': ['⚠️','#ef4444','Se requiere intervención académica. Contacta a tu coordinador.','bg-red-50 text-red-700'] };
    var n = niveles[data.nivel_desempeno] || niveles['En Desarrollo'];
    document.getElementById('modal-icono').innerHTML = '<span style="font-size:2rem">' + n[0] + '</span>';
    document.getElementById('modal-icono').className = 'w-16 h-16 mx-auto rounded-full flex items-center justify-center mb-4 ' + n[3];
    document.getElementById('modal-titulo').textContent = data.nivel_desempeno;
    document.getElementById('modal-puntaje').textContent = data.promedio + '%';
    document.getElementById('modal-puntaje').style.color = n[1];
    document.getElementById('modal-nivel').textContent = data.nivel_desempeno;
    document.getElementById('modal-mensaje').textContent = n[2];
    modal.classList.remove('hidden');
    modal.classList.add('flex');
  }
</script>
